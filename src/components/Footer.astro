---
import { SITE } from '../data/site';
import { withBase } from '../utils/url';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href={withBase('/')} class="logo">
        <span class="logo-script">by</span> <span class="logo-caps">NICOLAS VERDOT</span>
      </a>
      <p class="footer-tagline">{SITE.baseline}</p>
      <p class="footer-mission">Créer les conditions qui permettent au collectif de donner le meilleur de lui-même.</p>
    </div>

    <div class="footer-col">
      <h2>Offres</h2>
      <a href={withBase('/offres/')}>Toutes les offres</a>
      <a href={withBase('/offres/decider-ensemble/')}>Décider ensemble</a>
      <a href={withBase('/offres/aligner-equipe/')}>Aligner l'équipe</a>
      <a href={withBase('/offres/dynamique-durable/')}>Installer une dynamique durable</a>
    </div>

    <div class="footer-col">
      <h2>Accompagnements</h2>
      <a href={withBase('/offres/accompagnement-transformation/')}>Transformation</a>
      <a href={withBase('/offres/coaching-professionnel/')}>Coaching professionnel</a>
      <a href={withBase('/offres/capture-graphique/')}>Capture graphique</a>
      <a href={withBase('/formations/')}>Formations</a>
    </div>

    <div class="footer-col">
      <h2>Ressources</h2>
      <a href={withBase('/blog/')}>Blog</a>
      <a href={withBase('/approche/')}>Approche</a>
      <a href={withBase('/a-propos/')}>À propos</a>
      <a href={withBase('/charte-graphique/')}>Charte graphique</a>
    </div>

    <div class="footer-col">
      <h2>Contact</h2>
      <a href={SITE.bookingUrl} target="_blank" rel="noopener">Prendre rendez-vous</a>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; {year} Nicolas Verdot. Tous droits réservés.</span>
    <span class="footer-legal">Mentions légales · Confidentialité · Accessibilité : à venir</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink-solid);
    color: var(--color-white);
    margin-top: var(--space-24);
    padding: var(--space-12) 0 var(--space-6);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr 1fr 1fr;
    gap: var(--space-8) var(--space-6);
  }
  .logo {
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-2);
  }
  .logo-script {
    font-family: var(--font-script);
    color: var(--color-orange);
    font-size: 1.4rem;
  }
  .logo-caps {
    font-family: var(--font-display);
    font-weight: 900;
    color: var(--color-white);
    letter-spacing: -0.02em;
    font-size: 1rem;
  }
  .footer-tagline {
    margin: 0 0 var(--space-2);
    color: var(--color-white);
    font-weight: 600;
    font-size: var(--text-sm);
  }
  .footer-mission {
    margin: 0;
    color: #c6d0df;
    font-size: var(--text-sm);
    max-width: 32ch;
  }
  .footer-col h2 {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-orange);
    margin: 0 0 var(--space-3);
  }
  .footer-col {
    display: flex;
    flex-direction: column;
  }
  .footer-col a {
    color: #c6d0df;
    text-decoration: none;
    font-size: var(--text-sm);
    padding: var(--space-1) 0;
  }
  .footer-col a:hover {
    color: var(--color-white);
  }
  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    justify-content: space-between;
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: var(--text-xs);
    color: #95a4bb;
  }

  @media (max-width: 1000px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
      margin-bottom: var(--space-4);
    }
  }

  @media (max-width: 800px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
      margin-bottom: var(--space-4);
    }
  }
</style>
