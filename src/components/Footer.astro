---
import { SITE } from '../data/site';
import { withBase } from '../utils/url';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p class="footer-name">by <strong>Nicolas Verdot</strong></p>
      <p class="footer-tagline">{SITE.baseline}</p>
    </div>
    <div class="footer-contact">
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a>
    </div>
    <nav class="footer-nav">
      <a href={withBase('/approche/')}>Approche</a>
      <a href={withBase('/a-propos/')}>À propos</a>
      <a href={withBase('/contact/')}>Contact</a>
    </nav>
  </div>
  <p class="footer-copy container">&copy; {year} Nicolas Verdot. Tous droits réservés.</p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-white);
    margin-top: var(--space-24);
    padding: var(--space-12) 0 var(--space-6);
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
    justify-content: space-between;
  }
  .footer-name {
    font-weight: 400;
    margin: 0 0 var(--space-1);
    color: var(--color-navy);
  }
  .footer-tagline {
    margin: 0;
    color: #555;
    font-size: var(--text-sm);
  }
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer-contact a {
    color: var(--color-navy);
    text-decoration: none;
    font-size: var(--text-sm);
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer-nav a {
    color: #555;
    text-decoration: none;
    font-size: var(--text-sm);
  }
  .footer-copy {
    margin: var(--space-8) auto 0;
    font-size: var(--text-xs);
    color: #999;
  }
</style>
