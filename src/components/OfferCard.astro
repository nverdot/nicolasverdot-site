---
import { withBase } from '../utils/url';

interface Props {
  icon: string;
  title: string;
  text: string;
  href?: string;
}

const { icon, title, text, href = withBase('/contact/') } = Astro.props;
---

<a href={href} class="offer-card card-brut">
  <span class="offer-icon" aria-hidden="true">{icon}</span>
  <h3>{title}</h3>
  <p>{text}</p>
  <span class="offer-link">Découvrir →</span>
</a>

<style>
  .offer-card {
    display: block;
    background: var(--color-white);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
  }
  .offer-icon {
    display: inline-block;
    font-size: var(--text-2xl);
    color: var(--color-orange);
    margin-bottom: var(--space-2);
  }
  .offer-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  .offer-card p {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
    color: #444;
  }
  .offer-link {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-navy);
  }
</style>
