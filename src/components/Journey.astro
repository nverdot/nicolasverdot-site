---
import ChatCarousel from './ChatCarousel.astro';
import { journey } from '../data/journey';
import { conversations } from '../data/conversations';

interface Props {
  conversations: typeof conversations;
}
const { conversations: convos } = Astro.props;
---

<section class="journey" aria-label="Le parcours, étape par étape" data-section-name="Preuve / Journey (conversations WhatsApp)">
  <div class="container">
    <div class="journey-intro" data-reveal>
      <p class="eyebrow">Le chemin</p>
      <h2 class="prose">Du flou à la clarté. De la discussion à la décision. De la décision à l'action.</h2>
    </div>

    <div class="journey-steps">
      {journey.map((step, i) => (
        <article class="journey-step" data-reveal>
          <span class="journey-step-number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div class="journey-step-body">
            <p class="eyebrow">{step.eyebrow}</p>
            <h3>{step.title}</h3>
            <p class="hero-copy">{step.text}</p>
            <ul class="journey-bullets">
              {step.bullets.map((b) => <li>{b}</li>)}
            </ul>
            {i === 0 && (
              <div class="journey-proof">
                <p class="journey-proof-label">Ce que ça donne, concrètement :</p>
                <ChatCarousel conversations={convos} />
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .journey {
    padding: var(--space-24) 0;
  }
  .journey-intro {
    max-width: var(--prose-max);
    margin: 0 auto var(--space-16);
    text-align: center;
  }
  .journey-intro h2 {
    margin: 0 auto;
  }

  .journey-steps {
    display: grid;
    gap: var(--space-16);
  }

  .journey-step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .journey-step-number {
    width: 56px;
    height: 56px;
    display: grid;
    place-items: center;
    border-radius: 52% 48% 55% 45% / 47% 53% 46% 54%;
    background: var(--color-orange);
    color: var(--color-ink-solid);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
  }
  .journey-step:nth-child(even) .journey-step-number {
    border-radius: 46% 54% 48% 52% / 55% 45% 54% 46%;
  }

  .journey-step-body h3 {
    margin: var(--space-2) 0 var(--space-3);
    font-size: var(--text-2xl);
  }
  .journey-bullets {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }
  .journey-bullets li {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-navy);
    background: var(--color-blue-soft);
    padding: 0.35em 0.9em;
    border-radius: var(--radius-pill);
  }

  .journey-proof {
    margin-top: var(--space-12);
  }
  .journey-proof-label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-muted);
    margin: 0 0 var(--space-4);
  }

  @media (max-width: 720px) {
    .journey-step {
      grid-template-columns: 1fr;
    }
    .journey-step-number {
      width: 44px;
      height: 44px;
    }
  }
</style>
