---
import GroupChat from './GroupChat.astro';
import type { Conversation } from '../data/conversations';

interface Props {
  conversations: Conversation[];
}

const { conversations } = Astro.props;
---

<div class="chat-carousel">
  <div class="chat-carousel-track">
    {conversations.map((c, i) => (
      <div class="chat-carousel-slide" data-carousel-slide data-index={i} data-chat-id={c.id}>
        <p class="chat-label">{c.label}</p>
        <div class="chat-stage">
          <GroupChat id={c.id} title={c.title} people={c.people} steps={c.steps} />
          <div class="chat-insight-overlay">
            <div class="chat-insight-dialog">
              <p class="chat-insight-eyebrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6M10 22h4M12 2a6 6 0 0 0-4 10.5c.6.6 1 1.4 1 2.5h6c0-1.1.4-1.9 1-2.5A6 6 0 0 0 12 2z"/></svg>
                Regard d'expert
              </p>
              <p class="chat-insight-diagnosis">{c.insight.diagnosis}</p>
              <p class="chat-insight-action"><strong>Piste d'action :</strong> {c.insight.action}</p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="chat-carousel-dots">
    {conversations.map((c, i) => (
      <button type="button" class="chat-dot" data-dot data-index={i} aria-label={`Voir : ${c.label}`}></button>
    ))}
  </div>
</div>

<style>
  .chat-carousel {
    max-width: 560px;
    margin: var(--space-8) auto 0;
  }
  .chat-carousel-track {
    position: relative;
    overflow: hidden;
    min-height: 700px;
    transition: height 0.3s ease;
  }
  .chat-carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    transition: transform 0.35s ease, opacity 0.35s ease;
    transform-origin: center top;
  }
  .chat-carousel-slide:not(:first-child) {
    display: none;
  }
  .chat-label {
    text-align: center;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    margin: 0 0 var(--space-3);
  }
  .chat-carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: var(--space-6);
  }
  .chat-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: var(--color-border);
    cursor: pointer;
    transition: background var(--duration-standard) var(--ease-standard), transform var(--duration-standard) var(--ease-standard);
  }
  .chat-dot.is-active {
    background: var(--color-orange);
    transform: scale(1.3);
  }
  .chat-stage {
    position: relative;
  }
  .chat-stage :global(.chat-window) {
    transition: filter 0.5s ease;
  }
  .chat-stage :global(.chat-window.is-dimmed) {
    filter: grayscale(0.9) brightness(0.7);
  }
  .chat-insight-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
    background: rgba(10, 14, 20, 0);
    border-radius: var(--radius-lg);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease, background 0.5s ease;
  }
  .chat-insight-overlay.is-visible {
    opacity: 1;
    background: rgba(10, 14, 20, 0.6);
    pointer-events: auto;
  }
  .chat-insight-dialog {
    background: var(--color-surface);
    color: var(--color-ink);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    max-width: 360px;
    box-shadow: var(--shadow-lg);
    transform: scale(0.92) translateY(8px);
    transition: transform 0.5s ease;
  }
  .chat-insight-overlay.is-visible .chat-insight-dialog {
    transform: scale(1) translateY(0);
  }
  .chat-insight-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-orange-ink);
    margin: 0 0 var(--space-2);
  }
  .chat-insight-eyebrow svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .chat-insight-diagnosis {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-ink);
  }
  .chat-insight-action {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .chat-insight-action strong {
    color: var(--color-blue);
  }
</style>

<script>
  interface ChatEl extends HTMLElement {
    __play?: () => void;
    __played?: boolean;
  }

  document.querySelectorAll<HTMLElement>('.chat-carousel').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('.chat-carousel-track');
    if (track) {
      const slideEls = Array.from(track.children);
      for (let i = slideEls.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [slideEls[i], slideEls[j]] = [slideEls[j], slideEls[i]];
      }
      slideEls.forEach((el) => track.appendChild(el));
    }

    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-slide]'));
    const dots = Array.from(carousel.querySelectorAll<HTMLElement>('[data-dot]'));
    const total = slides.length;
    let index = 0;
    let started = false;
    let pendingAdvance: ReturnType<typeof setTimeout> | null = null;
    let dragPercent = 0;

    function wrap(i: number) {
      return (i + total) % total;
    }

    // Position current/prev/next in a small cascade: the neighbour sits
    // smaller, offset and faded behind the current card (not edge to edge),
    // and slides toward full size as a drag commits it to the centre.
    function styleSlide(slide: HTMLElement, pos: number, withTransition: boolean, isCurrent: boolean) {
      slide.style.transition = withTransition ? '' : 'none';
      const abs = Math.min(Math.abs(pos), 1.6);
      const scale = 1 - abs * 0.16;
      const opacity = Math.max(0, 1 - abs * 0.65);
      slide.style.transform = `translateX(${pos * 46}%) scale(${scale})`;
      slide.style.opacity = String(opacity);
      slide.style.zIndex = isCurrent ? '3' : '2';
    }

    function layout(withTransition: boolean) {
      const prevI = wrap(index - 1);
      const nextI = wrap(index + 1);
      slides.forEach((s, i) => {
        let baseOffset: number | null = null;
        if (i === index) baseOffset = 0;
        else if (i === prevI) baseOffset = -1;
        else if (i === nextI) baseOffset = 1;

        if (baseOffset === null) {
          s.style.display = 'none';
          return;
        }
        s.style.display = 'block';
        styleSlide(s, baseOffset + dragPercent, withTransition, i === index);

        // Only the truly centred slide may show its "done playing" state —
        // clear any leftover dim/overlay from when a neighbour was itself
        // the active slide, so peeking cards never show a stale dark scrim.
        if (i !== index) {
          s.querySelector('.chat-window')?.classList.remove('is-dimmed');
          s.querySelector('.chat-insight-overlay')?.classList.remove('is-visible');
        }
      });
      const active = slides[index];
      if (active) {
        requestAnimationFrame(() => {
          if (track) track.style.height = active.offsetHeight + 'px';
        });
      }
    }

    function resetSlide(slide: HTMLElement) {
      const chat = slide.querySelector<ChatEl>('.chat-window');
      const overlay = slide.querySelector('.chat-insight-overlay');
      overlay?.classList.remove('is-visible');
      chat?.classList.remove('is-dimmed');
      if (!chat) return;
      chat.__played = false;
      chat.querySelectorAll('[data-id]').forEach((el) => el.classList.remove('is-in'));
      chat.querySelectorAll('.chat-react').forEach((el) => el.classList.remove('is-in'));
      const body = chat.querySelector('.chat-body');
      if (body) body.scrollTop = 0;
    }

    function activate(i: number) {
      if (pendingAdvance) {
        clearTimeout(pendingAdvance);
        pendingAdvance = null;
      }
      index = wrap(i);
      dragPercent = 0;
      dots.forEach((d, di) => d.classList.toggle('is-active', di === index));
      layout(true);
      const slide = slides[index];
      resetSlide(slide);
      const chat = slide.querySelector<ChatEl>('.chat-window');
      requestAnimationFrame(() => chat?.__play?.());
    }

    function goToNext() {
      activate(index + 1);
    }

    function goToPrev() {
      activate(index - 1);
    }

    window.addEventListener('groupchat:done', ((e: CustomEvent<{ id: string }>) => {
      const activeSlide = slides[index];
      if (activeSlide?.dataset.chatId === e.detail.id) {
        activeSlide.querySelector('.chat-window')?.classList.add('is-dimmed');
        activeSlide.querySelector('.chat-insight-overlay')?.classList.add('is-visible');
        pendingAdvance = setTimeout(goToNext, 11000);
      }
    }) as EventListener);

    dots.forEach((d, i) => d.addEventListener('click', () => activate(i)));

    if (track) {
      let touchStartX = 0;
      let touchStartY = 0;
      let axisLocked: 'x' | 'y' | null = null;
      let dragging = false;

      track.addEventListener('touchstart', (e) => {
        if (pendingAdvance) {
          clearTimeout(pendingAdvance);
          pendingAdvance = null;
        }
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        axisLocked = null;
        dragging = false;
      }, { passive: true });

      track.addEventListener('touchmove', (e) => {
        const dx = e.touches[0].clientX - touchStartX;
        const dy = e.touches[0].clientY - touchStartY;
        if (!axisLocked) {
          if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return;
          axisLocked = Math.abs(dx) > Math.abs(dy) ? 'x' : 'y';
          if (axisLocked === 'x') dragging = true;
        }
        if (axisLocked !== 'x') return;
        e.preventDefault();
        const width = track!.clientWidth || 1;
        dragPercent = Math.max(-1, Math.min(1, dx / width));
        layout(false);
      }, { passive: false });

      track.addEventListener('touchend', () => {
        if (!dragging) {
          axisLocked = null;
          return;
        }
        dragging = false;
        axisLocked = null;
        if (dragPercent <= -0.18) {
          goToNext();
        } else if (dragPercent >= 0.18) {
          goToPrev();
        } else {
          dragPercent = 0;
          layout(true);
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;
            activate(0);
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    observer.observe(carousel);
  });
</script>
