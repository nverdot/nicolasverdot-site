---
import GroupChat from './GroupChat.astro';
import type { Conversation } from '../data/conversations';

interface Props {
  conversations: Conversation[];
}

const { conversations } = Astro.props;
---

<div class="chat-carousel">
  <div class="chat-carousel-track">
    {conversations.map((c, i) => (
      <div class="chat-carousel-slide" data-carousel-slide data-index={i} data-chat-id={c.id}>
        <p class="chat-label">{c.label}</p>
        <div class="chat-stage">
          <GroupChat id={c.id} title={c.title} people={c.people} steps={c.steps} />
          <div class="chat-insight-overlay">
            <div class="chat-insight-dialog">
              <p class="chat-insight-eyebrow">Regard d'expert</p>
              <p class="chat-insight-diagnosis">{c.insight.diagnosis}</p>
              <p class="chat-insight-action"><strong>Piste d'action :</strong> {c.insight.action}</p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="chat-carousel-dots">
    {conversations.map((c, i) => (
      <button type="button" class="chat-dot" data-dot data-index={i} aria-label={`Voir : ${c.label}`}></button>
    ))}
  </div>
</div>

<style>
  .chat-carousel {
    max-width: 560px;
    margin: var(--space-8) auto 0;
  }
  .chat-carousel-track {
    position: relative;
  }
  .chat-carousel-slide {
    display: none;
  }
  .chat-carousel-slide.is-active {
    display: block;
    animation: chat-slide-in 0.4s ease;
  }
  @keyframes chat-slide-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .chat-label {
    text-align: center;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    margin: 0 0 var(--space-3);
  }
  .chat-carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: var(--space-6);
  }
  .chat-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: var(--color-border);
    cursor: pointer;
    transition: background var(--duration-standard) var(--ease-standard), transform var(--duration-standard) var(--ease-standard);
  }
  .chat-dot.is-active {
    background: var(--color-orange);
    transform: scale(1.3);
  }
  .chat-stage {
    position: relative;
  }
  .chat-stage :global(.chat-window) {
    transition: filter 0.5s ease;
  }
  .chat-stage :global(.chat-window.is-dimmed) {
    filter: grayscale(0.9) brightness(0.7);
  }
  .chat-insight-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-5);
    background: rgba(10, 14, 20, 0);
    border-radius: var(--radius-lg);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease, background 0.5s ease;
  }
  .chat-insight-overlay.is-visible {
    opacity: 1;
    background: rgba(10, 14, 20, 0.6);
    pointer-events: auto;
  }
  .chat-insight-dialog {
    background: var(--color-surface);
    color: var(--color-ink);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    max-width: 360px;
    box-shadow: var(--shadow-lg);
    transform: scale(0.92) translateY(8px);
    transition: transform 0.5s ease;
  }
  .chat-insight-overlay.is-visible .chat-insight-dialog {
    transform: scale(1) translateY(0);
  }
  .chat-insight-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-orange-ink);
    margin: 0 0 var(--space-2);
  }
  .chat-insight-eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-orange);
  }
  .chat-insight-diagnosis {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-ink);
  }
  .chat-insight-action {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .chat-insight-action strong {
    color: var(--color-blue);
  }
</style>

<script>
  interface ChatEl extends HTMLElement {
    __play?: () => void;
    __played?: boolean;
  }

  document.querySelectorAll<HTMLElement>('.chat-carousel').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('.chat-carousel-track');
    if (track) {
      const slideEls = Array.from(track.children);
      for (let i = slideEls.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [slideEls[i], slideEls[j]] = [slideEls[j], slideEls[i]];
      }
      slideEls.forEach((el) => track.appendChild(el));
    }

    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-slide]'));
    const dots = Array.from(carousel.querySelectorAll<HTMLElement>('[data-dot]'));
    let index = 0;
    let started = false;
    let pendingAdvance: ReturnType<typeof setTimeout> | null = null;

    function resetSlide(slide: HTMLElement) {
      const chat = slide.querySelector<ChatEl>('.chat-window');
      const overlay = slide.querySelector('.chat-insight-overlay');
      overlay?.classList.remove('is-visible');
      chat?.classList.remove('is-dimmed');
      if (!chat) return;
      chat.__played = false;
      chat.querySelectorAll('[data-id]').forEach((el) => el.classList.remove('is-in'));
      chat.querySelectorAll('.chat-react').forEach((el) => el.classList.remove('is-in'));
      const body = chat.querySelector('.chat-body');
      if (body) body.scrollTop = 0;
    }

    function activate(i: number) {
      if (pendingAdvance) {
        clearTimeout(pendingAdvance);
        pendingAdvance = null;
      }
      index = (i + slides.length) % slides.length;
      slides.forEach((s, si) => s.classList.toggle('is-active', si === index));
      dots.forEach((d, di) => d.classList.toggle('is-active', di === index));
      const slide = slides[index];
      resetSlide(slide);
      const chat = slide.querySelector<ChatEl>('.chat-window');
      requestAnimationFrame(() => chat?.__play?.());
    }

    function goToNext() {
      activate(index + 1);
    }

    function goToPrev() {
      activate(index - 1);
    }

    window.addEventListener('groupchat:done', ((e: CustomEvent<{ id: string }>) => {
      const activeSlide = slides[index];
      if (activeSlide?.dataset.chatId === e.detail.id) {
        activeSlide.querySelector('.chat-window')?.classList.add('is-dimmed');
        activeSlide.querySelector('.chat-insight-overlay')?.classList.add('is-visible');
        pendingAdvance = setTimeout(goToNext, 6500);
      }
    }) as EventListener);

    dots.forEach((d, i) => d.addEventListener('click', () => activate(i)));

    let touchStartX = 0;
    let touchStartY = 0;
    carousel.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });
    carousel.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) goToNext();
        else goToPrev();
      }
    }, { passive: true });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;
            activate(0);
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    observer.observe(carousel);
  });
</script>
