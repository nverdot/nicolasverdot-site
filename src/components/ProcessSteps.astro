---
const steps = [
  { icon: '◎', title: 'Donner à voir', text: 'Clarifier les enjeux et rendre visibles les idées, les défis et les opportunités.' },
  { icon: '◌', title: 'Faire participer', text: "Faire émerger l'intelligence collective et créer les conditions de l'engagement." },
  { icon: '◇', title: 'Décider', text: 'Transformer les échanges en choix concrets. Prioriser. Aligner les énergies.' },
  { icon: '☼', title: 'Agir', text: 'Passer des intentions aux actions et construire un plan réaliste et mobilisateur.' },
  { icon: '✎', title: 'Apprendre', text: 'Observer, ajuster et progresser ensemble.' },
];
---

<ol class="process-steps">
  {
    steps.map((step, i) => (
      <li class="step card-brut">
        <span class="step-number">{i + 1}</span>
        <span class="step-icon" aria-hidden="true">{step.icon}</span>
        <h3>{step.title}</h3>
        <p>{step.text}</p>
      </li>
    ))
  }
</ol>

<style>
  .process-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-4);
  }
  .step {
    position: relative;
    background: var(--color-surface);
    padding: var(--space-6) var(--space-4);
  }
  .step-number {
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-border);
  }
  .step-icon {
    display: block;
    font-size: var(--text-2xl);
    color: var(--color-blue);
    margin-bottom: var(--space-2);
  }
  .step h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  .step p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .process-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
