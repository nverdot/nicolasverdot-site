---
// Dessins provisoires, style trait-à-main-levée : à remplacer par de vrais
// sketchnotes. Chaque forme porte pathLength="1", ce qui permet à
// Journey.astro de les "dessiner" au scroll via stroke-dashoffset, quelle
// que soit la longueur réelle du tracé.
interface Props {
  name: 'observer' | 'clarifier' | 'concevoir' | 'vivre' | 'decider' | 'ancrer';
}
const { name } = Astro.props;
---

<svg
  class="journey-icon"
  data-journey-icon
  viewBox="0 0 100 100"
  fill="none"
  stroke="currentColor"
  stroke-width="4"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {name === 'observer' && (
    <>
      <circle cx="40" cy="42" r="20" pathLength="1" />
      <line x1="55" y1="57" x2="80" y2="82" pathLength="1" />
      <path d="M26 18 Q18 8 29 5 Q39 2 34 13" pathLength="1" />
    </>
  )}
  {name === 'clarifier' && (
    <>
      <path d="M8 82 L36 28 L52 55 L68 18 L94 82 Z" pathLength="1" />
      <line x1="68" y1="18" x2="68" y2="3" pathLength="1" />
      <path d="M68 3 L86 9 L68 14 Z" pathLength="1" />
    </>
  )}
  {name === 'concevoir' && (
    <>
      <path d="M8 82 Q32 76 40 55 Q46 30 66 36 Q84 40 92 12" pathLength="1" />
      <circle cx="40" cy="55" r="4.5" pathLength="1" />
      <circle cx="66" cy="36" r="4.5" pathLength="1" />
    </>
  )}
  {name === 'vivre' && (
    <>
      <rect x="20" y="12" width="60" height="46" rx="4" pathLength="1" />
      <line x1="30" y1="27" x2="57" y2="24" pathLength="1" />
      <line x1="30" y1="37" x2="66" y2="35" pathLength="1" />
      <line x1="30" y1="47" x2="48" y2="46" pathLength="1" />
      <circle cx="14" cy="86" r="6" pathLength="1" />
      <circle cx="40" cy="91" r="6" pathLength="1" />
      <circle cx="66" cy="88" r="6" pathLength="1" />
      <circle cx="90" cy="80" r="6" pathLength="1" />
    </>
  )}
  {name === 'decider' && (
    <>
      <circle cx="14" cy="18" r="3" pathLength="1" />
      <circle cx="30" cy="8" r="3" pathLength="1" />
      <circle cx="8" cy="38" r="3" pathLength="1" />
      <circle cx="33" cy="34" r="3" pathLength="1" />
      <path d="M18 68 L40 88 L90 26" pathLength="1" />
    </>
  )}
  {name === 'ancrer' && (
    <>
      <path d="M8 92 L8 76 L28 76 L28 60 L48 60 L48 44 L68 44 L68 24" pathLength="1" />
      <circle cx="78" cy="16" r="8" pathLength="1" />
      <line x1="78" y1="24" x2="78" y2="40" pathLength="1" />
    </>
  )}
</svg>

<style is:global>
  .journey-icon {
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .journey-icon > * {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 900ms var(--ease-out);
  }
  .journey-icon > *:nth-child(1) {
    transition-delay: 0ms;
  }
  .journey-icon > *:nth-child(2) {
    transition-delay: 150ms;
  }
  .journey-icon > *:nth-child(3) {
    transition-delay: 300ms;
  }
  .journey-icon > *:nth-child(4) {
    transition-delay: 450ms;
  }
  .journey-icon > *:nth-child(5) {
    transition-delay: 600ms;
  }
  .journey-icon > *:nth-child(6) {
    transition-delay: 750ms;
  }
  [data-reveal].is-visible .journey-icon > * {
    stroke-dashoffset: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .journey-icon > * {
      transition-duration: 0.001ms !important;
    }
  }
</style>
