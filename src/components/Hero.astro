---
import { SITE } from '../data/site';
import { withBase } from '../utils/url';

// Icônes maison, traits façon feutre (currentColor, coins arrondis) —
// mêmes conventions que le reste du site (pas de librairie d'icônes).
const icons: Record<string, string> = {
  note: '<rect x="9" y="6" width="22" height="28" rx="2"/><path d="M14 15h12M14 21h12M14 27h7"/>',
  people: '<circle cx="12" cy="14" r="5"/><path d="M4 32c0-5 3.5-9 8-9s8 4 8 9"/><circle cx="27" cy="16" r="4"/><path d="M22 32c.3-4 2.5-7 5-7"/>',
  hourglass: '<path d="M11 6h18M11 34h18M13 6c0 8 14 8 14 14s-14 6-14 14M27 6c0 8-14 8-14 14s14 6 14 14"/>',
  battery: '<rect x="6" y="13" width="24" height="14" rx="2"/><path d="M30 17h4v6h-4z" fill="currentColor" stroke="none"/><path d="M10 17v6M15 17v6" stroke-width="4"/>',
  question: '<path d="M13 14c0-4 3-7 7-7s7 3 7 6c0 5-6 5-6 10"/><circle cx="20" cy="31" r="1.4" fill="currentColor" stroke="none"/>',
  cloud: '<path d="M11 27a6 6 0 0 1-1-11.9A8 8 0 0 1 25 12a6.5 6.5 0 0 1 3 12.4"/><path d="M11 27h17"/>',
  bulb: '<circle cx="20" cy="15" r="9"/><path d="M16 30h8M17 33h6"/><path d="M20 6v0M20 24v6"/>',
  signpost: '<path d="M20 6v28"/><path d="M20 12h11l-3 4 3 4H20z"/><path d="M20 18H9l3-3M9 18l3 3"/>',
  rocket: '<path d="M20 5c5 3 7 9 7 15 0 4-2 8-7 12-5-4-7-8-7-12 0-6 2-12 7-15z"/><circle cx="20" cy="17" r="2.6"/><path d="M13 26l-4 6 6-2M27 26l4 6-6-2"/>',
};
const Icon = (name: string) => icons[name] ?? '';

const loopNodes = [
  { icon: 'note', label: 'Les mêmes sujets' },
  { icon: 'people', label: "Réunions qui s'éternisent" },
  { icon: 'hourglass', label: 'Décisions repoussées' },
  { icon: 'battery', label: "Énergie qui s'épuise" },
  { icon: 'question', label: 'Aucune clarté' },
  { icon: 'cloud', label: 'Perspectives floues' },
];
const exitNodes = [
  { icon: 'bulb', label: 'Clarté' },
  { icon: 'signpost', label: 'Décider' },
  { icon: 'rocket', label: 'Agir' },
];
---

<section class="hero" aria-labelledby="hero-title" data-section-name="Hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Comprendre. Décider. Agir.</p>

      <h1 id="hero-title">
        Vous tournez en rond.
        <span class="accent-wrap">
          <span class="accent">On sort du cercle.</span>
          <svg class="ink-underline" viewBox="0 0 300 16" preserveAspectRatio="none" aria-hidden="true"><path d="M4 10 C 70 2, 150 14, 296 6" /></svg>
        </span>
      </h1>

      <p class="hero-lead">
        J'accompagne les leaders, les managers et les équipes à <strong>voir clair</strong>, <strong>prendre les bonnes décisions</strong> et <strong>passer réellement à l'action</strong>.
      </p>

      <div class="hero-actions">
        <a href={withBase('/#accompagnements')} class="btn">Voir les accompagnements →</a>
        <a href={withBase('/contact/')} class="btn-outline">Échangeons ensemble</a>
      </div>
    </div>

    <div class="hero-loop" aria-hidden="true">
      <svg class="loop-svg" viewBox="0 0 600 520" preserveAspectRatio="xMidYMid meet">
        <path class="loop-track" d="M180 90 C 90 120, 65 260, 145 350 C 225 440, 380 420, 405 310 C 425 225, 340 105, 180 90" />
        <path class="exit-track" d="M405 310 C 460 335, 500 320, 535 275 C 565 235, 580 195, 600 150" />
        <circle class="loop-runner runner-1" r="8" />
        <circle class="loop-runner runner-2" r="5.5" />
      </svg>

      <div class="loop-center">
        <span class="loop-center-icon" set:html={Icon('people')} />
        <strong>On en reparle ?</strong>
      </div>

      <div class="break-point"><span>STOP</span></div>

      <div class="loop-node node-1"><svg viewBox="0 0 40 40" set:html={Icon(loopNodes[0].icon)} /><span>{loopNodes[0].label}</span></div>
      <div class="loop-node node-2"><svg viewBox="0 0 40 40" set:html={Icon(loopNodes[1].icon)} /><span>{loopNodes[1].label}</span></div>
      <div class="loop-node node-3"><svg viewBox="0 0 40 40" set:html={Icon(loopNodes[2].icon)} /><span>{loopNodes[2].label}</span></div>
      <div class="loop-node node-4"><svg viewBox="0 0 40 40" set:html={Icon(loopNodes[3].icon)} /><span>{loopNodes[3].label}</span></div>
      <div class="loop-node node-5"><svg viewBox="0 0 40 40" set:html={Icon(loopNodes[4].icon)} /><span>{loopNodes[4].label}</span></div>
      <div class="loop-node node-6"><svg viewBox="0 0 40 40" set:html={Icon(loopNodes[5].icon)} /><span>{loopNodes[5].label}</span></div>

      <div class="exit-node exit-1"><svg viewBox="0 0 40 40" set:html={Icon(exitNodes[0].icon)} /><span>{exitNodes[0].label}</span></div>
      <div class="exit-node exit-2"><svg viewBox="0 0 40 40" set:html={Icon(exitNodes[1].icon)} /><span>{exitNodes[1].label}</span></div>
      <div class="exit-node exit-3"><svg viewBox="0 0 40 40" set:html={Icon(exitNodes[2].icon)} /><span>{exitNodes[2].label}</span></div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const mm = gsap.matchMedia();

  mm.add(
    { reduceMotion: '(prefers-reduced-motion: reduce)' },
    (context) => {
      const { reduceMotion } = context.conditions ?? {};
      // Seuls les 6 nœuds de la boucle passent par GSAP (révélation one-shot
      // au chargement) — les 3 nœuds de sortie ont leur propre animation
      // CSS cyclique (hero-loop-exit-in) : leur laisser un style inline
      // GSAP entrait en conflit avec cette animation et les gardait à
      // opacity:0 en permanence.
      const nodes = gsap.utils.toArray<HTMLElement>('.loop-node');
      const center = document.querySelector('.loop-center');

      if (reduceMotion) {
        gsap.set(nodes, { clearProps: 'all' });
      } else {
        gsap.set(nodes, { opacity: 0, scale: 0.5 });
        gsap.set(center, { opacity: 0, scale: 0.7 });
        const tl = gsap.timeline({ delay: 0.15 });
        tl.to(center, { opacity: 1, scale: 1, duration: 0.5, ease: 'back.out(1.6)' })
          .to(nodes, { opacity: 1, scale: 1, duration: 0.55, ease: 'back.out(1.7)', stagger: 0.06 }, 0.15);
      }

      return () => {
        nodes.forEach((n) => gsap.killTweensOf(n));
        if (center) gsap.killTweensOf(center);
      };
    }
  );
</script>

<style>
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-8);
    align-items: center;
  }
  .hero-copy h1 {
    margin: var(--space-3) 0 var(--space-4);
    font-size: clamp(2.1rem, 4vw, 3.1rem);
  }
  .accent-wrap {
    position: relative;
    display: block;
  }
  .accent {
    color: var(--color-orange-ink);
  }
  .ink-underline {
    position: absolute;
    left: 0;
    bottom: -0.2em;
    width: 60%;
    height: 0.25em;
    stroke: var(--color-orange);
    stroke-width: 5;
    fill: none;
  }
  .hero-lead {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 46ch;
  }
  .hero-lead strong {
    color: var(--color-navy);
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }

  /* --- Diagramme "boucle qui se brise" --- */
  .hero-loop {
    position: relative;
    width: 100%;
    max-width: 600px;
    aspect-ratio: 600 / 520;
    margin-inline: auto;
  }
  .loop-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .loop-track {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2.5;
    opacity: 0.75;
  }
  .exit-track {
    fill: none;
    stroke: var(--color-orange);
    stroke-width: 7;
    stroke-linecap: round;
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    animation: hero-loop-draw 5.5s ease-in-out infinite;
  }
  .loop-runner {
    fill: var(--color-clay);
    stroke: var(--color-surface);
    stroke-width: 3;
    offset-path: path("M180 90 C 90 120, 65 260, 145 350 C 225 440, 380 420, 405 310 C 425 225, 340 105, 180 90");
    animation: hero-loop-run 5.5s cubic-bezier(0.55, 0.02, 0.45, 0.98) infinite;
  }
  .runner-2 {
    fill: var(--color-orange);
    animation-delay: -1.6s;
    opacity: 0.9;
  }

  .loop-center {
    position: absolute;
    z-index: 3;
    top: 47%;
    left: 30%;
    width: 22%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border: 2px solid var(--color-ink);
    background: var(--color-surface);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.3em;
    padding: var(--space-2);
    box-shadow: var(--shadow-md);
  }
  .loop-center-icon {
    width: 34%;
    color: var(--color-ink);
  }
  .loop-center-icon :global(svg) {
    width: 100%;
    height: auto;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .loop-center strong {
    font-family: var(--font-display);
    font-size: clamp(0.7rem, 1.3vw, 0.85rem);
    line-height: 1.15;
  }

  .break-point {
    position: absolute;
    z-index: 6;
    left: 68%;
    top: 57%;
    width: 58px;
    height: 58px;
    background: var(--color-clay);
    color: var(--color-white);
    border: 3px solid var(--color-surface);
    border-radius: 50%;
    display: grid;
    place-items: center;
    box-shadow: 0 0 0 2px var(--color-ink);
    transform: rotate(-8deg);
    animation: hero-loop-break-pulse 5.5s ease-in-out infinite;
  }
  .break-point span {
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.04em;
  }

  .loop-node,
  .exit-node {
    position: absolute;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4em;
    width: 92px;
  }
  .loop-node svg,
  .exit-node svg {
    width: 34px;
    height: 34px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    color: var(--color-ink);
  }
  .exit-node svg {
    color: var(--color-orange-ink);
  }
  .loop-node span,
  .exit-node span {
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-navy);
  }

  .node-1 { top: -2%; left: 27%; }
  .node-2 { top: 12%; left: 62%; }
  .node-3 { top: 45%; left: 71%; }
  .node-4 { bottom: 4%; left: 46%; }
  .node-5 { bottom: 6%; left: 6%; }
  .node-6 { top: 22%; left: -4%; }

  .exit-node {
    opacity: 0;
    animation: hero-loop-exit-in 5.5s ease-in-out infinite;
  }
  .exit-1 { top: 42%; right: -2%; animation-delay: 0.1s; }
  .exit-2 { top: 20%; right: 6%; animation-delay: 0.28s; }
  .exit-3 { top: 0%; right: 20%; animation-delay: 0.46s; }

  @keyframes hero-loop-run {
    0% { offset-distance: 0%; opacity: 0; }
    8% { opacity: 1; }
    68% { offset-distance: 100%; opacity: 1; }
    74%, 100% { offset-distance: 100%; opacity: 0; }
  }
  @keyframes hero-loop-draw {
    0%, 62% { stroke-dashoffset: 300; opacity: 0; }
    68% { opacity: 1; }
    84%, 100% { stroke-dashoffset: 0; opacity: 1; }
  }
  @keyframes hero-loop-exit-in {
    0%, 69% { opacity: 0; transform: translateY(8px); }
    78%, 96% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-4px); }
  }
  @keyframes hero-loop-break-pulse {
    0%, 58% { transform: rotate(-8deg) scale(0.9); }
    65%, 76% { transform: rotate(-8deg) scale(1.15); }
    100% { transform: rotate(-8deg) scale(0.9); }
  }

  @media (prefers-reduced-motion: reduce) {
    .loop-runner { display: none; }
    .exit-track { stroke-dashoffset: 0; opacity: 1; animation: none; }
    .exit-node { opacity: 1; transform: none; animation: none; }
    .break-point { animation: none; }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-loop {
      margin-top: var(--space-10);
      max-width: 480px;
    }
  }

  /* En dessous de 640px, le diagramme spatial se resserre trop pour rester
     lisible (8 étiquettes + icônes) — on recompose en grille simple plutôt
     que de forcer la mise en page circulaire à une échelle où elle casse. */
  @media (max-width: 640px) {
    .hero-loop {
      aspect-ratio: auto;
      max-width: 420px;
    }
    .loop-svg,
    .break-point {
      display: none;
    }
    .loop-center {
      position: static;
      transform: none;
      width: 160px;
      margin: 0 auto var(--space-6);
    }
    .loop-node,
    .exit-node {
      position: static;
      width: auto;
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .hero-loop {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5) var(--space-2);
    }
    .loop-center {
      grid-column: 1 / -1;
    }
  }
</style>
