---
import { SITE } from '../data/site';
import { withBase } from '../utils/url';

// Le titre joue sur le double sens de "tourner en rond" (bloqué / en boucle)
// — la partie qui répond au problème ("on remet du mouvement") porte un
// surlignage jaune, le reste reste en texte plein. Piloté par un tableau
// plutôt que du HTML en dur pour garder l'effet de révélation masquée
// mot par mot (voir le script plus bas) sans dupliquer la logique.
const titleWords = [
  { t: 'Quand', hl: false },
  { t: 'ça', hl: false },
  { t: 'tourne', hl: false },
  { t: 'en', hl: false },
  { t: 'rond,', hl: false },
  { t: 'on', hl: true },
  { t: 'remet', hl: true },
  { t: 'du', hl: true },
  { t: 'mouvement.', hl: true },
];

const orbitCards = [
  { title: 'Voir clair', text: 'Nommer ce qui se joue vraiment.' },
  { title: 'Décider', text: 'Sortir du consensus mou.' },
  { title: 'Agir', text: 'Repartir avec une suite concrète.' },
];
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Boosteur de leaders et d'équipes</p>

      <h1 id="hero-title">
        {titleWords.map((w) => (
          <>
            <span class:list={['word-mask', { 'is-highlight': w.hl }]}><span class="word" data-word>{w.t}</span></span>{' '}
          </>
        ))}
      </h1>

      <p class="hero-lead">J'aide les dirigeants, managers et équipes à voir ce qui bloque, prendre des décisions utiles et transformer les échanges en actions concrètes.</p>

      <div class="hero-actions">
        <a href={withBase('/contact/')} class="btn">Parler de ce qui coince →</a>
        <a href={withBase('/#accompagnements')} class="btn-outline">Voir les accompagnements</a>
      </div>
      <p class="hero-pillars">Facilitation · Coaching · Séminaires · Transformation · Formation</p>
    </div>

    <div class="hero-orbit" aria-hidden="true">
      <div class="orbit-ring"></div>
      <div class="orbit-dot-wrap" data-orbit-dot-wrap>
        <span class="orbit-dot"></span>
      </div>
      <div class="orbit-center">
        <span>COMPRENDRE</span>
        <span>→ DÉCIDER</span>
        <span>→ AGIR</span>
      </div>
      <article class="orbit-card orbit-card-1" data-orbit-card>
        <strong>Voir clair</strong>
        <span>Nommer ce qui se joue vraiment.</span>
      </article>
      <article class="orbit-card orbit-card-2" data-orbit-card>
        <strong>Décider</strong>
        <span>Sortir du consensus mou.</span>
      </article>
      <article class="orbit-card orbit-card-3" data-orbit-card>
        <strong>Agir</strong>
        <span>Repartir avec une suite concrète.</span>
      </article>
      <svg class="orbit-wave" viewBox="0 0 400 60" preserveAspectRatio="none"><path d="M2 30 C 60 5, 120 55, 180 30 S 300 5, 398 35" fill="none" /></svg>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const mm = gsap.matchMedia();

  mm.add(
    { reduceMotion: '(prefers-reduced-motion: reduce)' },
    (context) => {
      const { reduceMotion } = context.conditions ?? {};
      const words = gsap.utils.toArray<HTMLElement>('[data-word]');
      const cards = gsap.utils.toArray<HTMLElement>('[data-orbit-card]');
      const dotWrap = document.querySelector<HTMLElement>('[data-orbit-dot-wrap]');

      if (reduceMotion) {
        gsap.set(words, { clearProps: 'all' });
        gsap.set(cards, { clearProps: 'all' });
      } else {
        // Titre : révélation masquée mot par mot, plus net qu'un fondu.
        // Cartes de l'orbite : arrivent en éventail depuis le centre, avec
        // un léger rebond, dans l'ordre où on les lit visuellement.
        const tl = gsap.timeline({ delay: 0.1 });
        tl.set(words, { yPercent: 110, rotate: 6 })
          .set(cards, { opacity: 0, scale: 0.6, x: 0, y: 0 })
          .to(words, { yPercent: 0, rotate: 0, duration: 0.85, ease: 'power4.out', stagger: 0.045 })
          .to(cards, { opacity: 1, scale: 1, duration: 0.8, ease: 'back.out(1.5)', stagger: 0.15 }, 0.3);
      }

      // "Un truc qui tourne en rond" : un point orbite en continu sur le
      // cercle en pointillés — la seule animation en boucle infinie de la
      // page, réservée à cet unique élément décoratif (aria-hidden), donc
      // coupée sous reduced-motion plutôt qu'atténuée.
      if (!reduceMotion && dotWrap) {
        gsap.to(dotWrap, { rotation: 360, duration: 14, ease: 'none', repeat: -1, transformOrigin: '50% 50%' });
      }

      return () => {
        words.forEach((w) => gsap.killTweensOf(w));
        cards.forEach((c) => gsap.killTweensOf(c));
        if (dotWrap) gsap.killTweensOf(dotWrap);
      };
    }
  );
</script>

<style>
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .hero-copy h1 {
    margin: var(--space-3) 0 var(--space-4);
  }

  .word-mask {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    padding-bottom: 0.08em;
  }
  .word-mask.is-highlight {
    background: var(--color-orange);
    padding: 0 0.12em 0.08em;
    border-radius: 2px;
  }
  .word {
    display: inline-block;
    will-change: transform;
  }

  .hero-lead {
    display: block;
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 46ch;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }
  .hero-pillars {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  /* --- Diagramme orbital --- */
  .hero-orbit {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 1;
    margin-inline: auto;
  }
  .orbit-ring {
    position: absolute;
    inset: 8%;
    border: 2px dashed var(--color-border);
    border-radius: 50%;
  }
  .orbit-center {
    position: absolute;
    top: 50%;
    left: 46%;
    width: 40%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    background: var(--color-orange);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.15em;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(0.85rem, 1.6vw, 1.05rem);
    color: var(--color-ink-solid);
    box-shadow: var(--shadow-md);
  }
  .orbit-dot-wrap {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    pointer-events: none;
  }
  .orbit-dot {
    position: absolute;
    top: -8px;
    left: 50%;
    width: 16px;
    height: 16px;
    margin-left: -8px;
    border-radius: 50%;
    background: var(--color-red-bright);
    box-shadow: 0 0 0 5px color-mix(in srgb, var(--color-red-bright) 18%, transparent);
  }

  .orbit-card {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    box-shadow: var(--shadow-md);
    width: 44%;
  }
  .orbit-card strong {
    font-size: var(--text-base);
  }
  .orbit-card span {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .orbit-card-1 {
    top: 2%;
    left: 2%;
    transform: rotate(-3deg);
  }
  .orbit-card-2 {
    top: 30%;
    right: 0%;
    transform: rotate(4deg);
  }
  .orbit-card-3 {
    bottom: 6%;
    left: 6%;
    transform: rotate(-2deg);
  }

  .orbit-wave {
    position: absolute;
    bottom: -4%;
    left: 10%;
    width: 80%;
    height: auto;
    stroke: var(--color-ink);
    stroke-width: 2.5;
    stroke-linecap: round;
    opacity: 0.55;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-orbit {
      margin-top: var(--space-12);
      max-width: 420px;
    }
    /* Le cercle central est plus petit ici pour ne plus passer sous la
       carte "Décider" — à 520px de large, les deux se chevauchaient. */
    .orbit-center {
      width: 34%;
      left: 42%;
    }
    .orbit-card-2 {
      top: 34%;
    }
  }

  @media (max-width: 520px) {
    .orbit-card {
      padding: var(--space-2) var(--space-3);
    }
    .orbit-card span {
      font-size: var(--text-xs);
    }
  }
</style>
