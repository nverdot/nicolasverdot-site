---
import { Image } from 'astro:assets';
import { withBase } from '../utils/url';
import heroLoop from '../assets/hero-loop.jpg';

// Étiquettes posées sur l'illustration (image sans texte) — position en %
// calée sur les icônes dessinées dans l'image.
const loopLabels = [
  { label: 'Les mêmes sujets', top: 4, left: 38 },
  { label: "Réunions qui s'éternisent", top: 15, left: 66 },
  { label: 'Perspectives floues', top: 31, left: 10 },
  { label: 'Décisions repoussées', top: 70, left: 66 },
  { label: 'Aucune clarté', top: 68, left: 10 },
  { label: "Énergie qui s'épuise", top: 87, left: 37 },
];
const exitLabels = [
  { label: 'Clarté', top: 48, left: 93 },
  { label: 'Décider', top: 64, left: 94 },
  { label: 'Agir', top: 82, left: 92 },
];
---

<section class="hero" aria-labelledby="hero-title" data-section-name="Hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <h1 id="hero-title">
        Vous tournez en rond.
        <span class="accent-wrap">
          <span class="accent">On sort du cercle.</span>
          <svg class="ink-underline" viewBox="0 0 300 16" preserveAspectRatio="none" aria-hidden="true"><path d="M4 10 C 70 2, 150 14, 296 6" /></svg>
        </span>
      </h1>

      <p class="hero-lead">
        J'accompagne les leaders, les managers et les équipes à <strong>voir clair</strong>, <strong>prendre les bonnes décisions</strong> et <strong>passer réellement à l'action</strong>.
      </p>

      <div class="hero-actions">
        <a href={withBase('/#accompagnements')} class="btn">Voir les accompagnements →</a>
        <a href={withBase('/contact/')} class="btn-outline">Échangeons ensemble</a>
      </div>
    </div>

    <div class="hero-loop" aria-hidden="true">
      <Image src={heroLoop} alt="" class="loop-img" widths={[420, 700, 1000]} sizes="(max-width: 900px) 90vw, 640px" />

      {loopLabels.map((n, i) => (
        <span class="loop-label" style={`top:${n.top}%; left:${n.left}%;`} data-label data-i={i}>{n.label}</span>
      ))}
      {exitLabels.map((n, i) => (
        <span class="loop-label exit-label" style={`top:${n.top}%; left:${n.left}%;`} data-label data-i={loopLabels.length + i}>{n.label}</span>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const mm = gsap.matchMedia();

  mm.add({ reduceMotion: '(prefers-reduced-motion: reduce)' }, (context) => {
    const { reduceMotion } = context.conditions ?? {};
    const labels = gsap.utils.toArray<HTMLElement>('[data-label]');

    if (reduceMotion) {
      gsap.set(labels, { clearProps: 'all' });
    } else {
      gsap.set(labels, { opacity: 0, y: 10, scale: 0.92 });
      gsap.to(labels, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 0.55,
        ease: 'back.out(1.6)',
        stagger: 0.07,
        delay: 0.2,
      });
    }

    return () => gsap.killTweensOf(labels);
  });
</script>

<style>
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-8);
    align-items: center;
  }
  .hero-copy h1 {
    margin: var(--space-3) 0 var(--space-4);
    font-size: clamp(2.1rem, 4vw, 3.1rem);
  }
  .accent-wrap {
    position: relative;
    display: block;
  }
  .accent {
    color: var(--color-orange-ink);
  }
  .ink-underline {
    position: absolute;
    left: 0;
    bottom: -0.2em;
    width: 60%;
    height: 0.25em;
    stroke: var(--color-orange);
    stroke-width: 5;
    fill: none;
  }
  .hero-lead {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 46ch;
  }
  .hero-lead strong {
    color: var(--color-navy);
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }
  /* --- Diagramme "boucle qui se brise" --- */
  .hero-loop {
    position: relative;
    width: 100%;
    max-width: 640px;
    aspect-ratio: 1536 / 1024;
    margin-inline: auto;
  }
  .hero-loop :global(.loop-img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .loop-label {
    position: absolute;
    z-index: 3;
    transform: translate(-50%, -50%);
    max-width: 15%;
    text-align: center;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1.15;
    font-size: clamp(0.6rem, 1.15vw, 0.82rem);
    color: var(--color-navy);
  }
  .loop-label.exit-label {
    color: var(--color-orange-ink);
    max-width: 13%;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-loop {
      margin-top: var(--space-8);
      max-width: 480px;
    }
  }

  @media (max-width: 640px) {
    .hero-loop {
      max-width: 420px;
    }
    .loop-label {
      max-width: 20%;
      font-size: clamp(0.5rem, 2.6vw, 0.62rem);
    }
    .loop-label.exit-label {
      max-width: 17%;
    }
  }
</style>
