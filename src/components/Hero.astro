---
import { Image } from 'astro:assets';
import portrait from '../assets/nicolas-portrait.png';
import action from '../assets/nicolas-action.jpeg';
import { SITE } from '../data/site';
import { withBase } from '../utils/url';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Leader facilitateur pour collectifs en mouvement</p>
      <h1 id="hero-title">
        Du collectif qui discute au <span class="hero-pen">collectif qui agit<svg class="ink-underline" viewBox="0 0 600 30" preserveAspectRatio="none" aria-hidden="true"><path d="M6 20 C 120 8, 250 6, 360 14 S 540 26, 594 12" /></svg></span> <span class="accent-italic">vraiment.</span>
      </h1>
      <p class="hero-lead">
        Vous ne manquez pas d'idées. Il manque souvent la posture, les techniques et le cadre pour transformer les discussions, les priorités et les tensions en décisions utiles et en actions réelles.
      </p>
      <div class="editorial-beats" aria-label="Ma méthode">
        <span class="is-teal">Clarifier</span>
        <span class="is-red">Décider</span>
        <span class="is-ochre">Faire</span>
      </div>
      <div class="hero-actions">
        <a href={SITE.bookingUrl} class="btn" target="_blank" rel="noopener">Prendre rendez-vous</a>
        <a href={withBase('/#accompagnements')} class="btn-outline">Voir ce que je propose</a>
      </div>
      <p class="hero-promise">
        Le résultat attendu : <strong>moins de dispersion, plus d'engagement</strong>, des responsabilités claires et des actions assumées dès lundi.
      </p>
    </div>
    <aside class="hero-photo" aria-label="Nicolas Verdot sur le terrain">
      <Image src={portrait} alt="Portrait de Nicolas Verdot" width={420} height={520} class="hero-photo-main" />
      <div class="hero-photo-note">
        <strong>by Nicolas Verdot</strong>
        <span>Tenir le cadre. Rendre visible. Passer au faire.</span>
      </div>
      <Image src={action} alt="Nicolas Verdot en facilitation graphique" width={260} height={200} class="hero-photo-action" />
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-16);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-orange-ink);
    margin-bottom: var(--space-3);
  }
  .hero-copy h1 {
    margin-bottom: var(--space-4);
  }
  .hero-pen {
    position: relative;
    display: inline-block;
  }
  .ink-underline {
    position: absolute;
    left: 0;
    bottom: -0.15em;
    width: 100%;
    height: 0.3em;
    stroke: var(--color-orange);
    stroke-width: 6;
    fill: none;
  }
  .hero-lead {
    font-size: var(--text-lg);
    color: #333;
  }
  .editorial-beats {
    display: flex;
    gap: var(--space-3);
    margin: var(--space-4) 0 var(--space-6);
  }
  .editorial-beats span {
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: var(--text-sm);
  }
  .editorial-beats .is-teal {
    background: #eef0e9;
    color: #4b5a3f;
  }
  .editorial-beats .is-red {
    background: #fbe2e2;
    color: var(--color-green);
  }
  .editorial-beats .is-ochre {
    background: #fbf0d2;
    color: var(--color-orange-ink);
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .hero-promise {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    color: #555;
  }

  .hero-photo {
    position: relative;
  }
  .hero-photo :global(.hero-photo-main) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .hero-photo-note {
    position: absolute;
    left: var(--space-4);
    bottom: var(--space-4);
    background: var(--color-navy);
    color: var(--color-white);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 2px;
    max-width: 220px;
  }
  .hero-photo-note strong {
    font-family: var(--font-display);
    font-size: var(--text-sm);
  }
  .hero-photo-note span {
    font-size: var(--text-xs);
    color: #d9d4c8;
  }
  .hero-photo :global(.hero-photo-action) {
    position: absolute;
    top: -10%;
    right: -12%;
    width: 45%;
    height: auto;
    border-radius: var(--radius-md);
    border: 4px solid var(--color-cream);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-photo {
      order: -1;
      margin-bottom: var(--space-8);
    }
    .hero-photo :global(.hero-photo-action) {
      display: none;
    }
  }
</style>
