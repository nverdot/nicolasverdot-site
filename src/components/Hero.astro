---
import { SITE } from '../data/site';
import { withBase } from '../utils/url';

// Le titre joue sur le double sens de "tourner en rond" (bloqué / en boucle)
// — la partie qui répond au problème ("on remet du mouvement") porte un
// surlignage jaune, le reste reste en texte plein. Piloté par un tableau
// plutôt que du HTML en dur pour garder l'effet de révélation masquée
// mot par mot (voir le script plus bas) sans dupliquer la logique.
const titleWords = [
  { t: 'Quand', hl: false },
  { t: 'ça', hl: false },
  { t: 'tourne', hl: false },
  { t: 'en', hl: false },
  { t: 'rond,', hl: false },
  { t: 'on', hl: true },
  { t: 'remet', hl: true },
  { t: 'du', hl: true },
  { t: 'mouvement.', hl: true },
];

const loopCards = [
  { t: 'Le même sujet', s: 'revient chaque semaine' },
  { t: 'La même tension', s: "jamais nommée" },
  { t: 'Le même flou', s: 'sur qui tranche' },
];
const exitCards = [
  { t: 'Décider', s: 'un choix assumé' },
  { t: 'Agir', s: 'un premier pas' },
];
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Boosteur de leaders et d'équipes</p>

      <h1 id="hero-title">
        {titleWords.map((w) => (
          <>
            <span class:list={['word-mask', { 'is-highlight': w.hl }]}><span class="word" data-word>{w.t}</span></span>{' '}
          </>
        ))}
      </h1>

      <p class="hero-lead">J'aide les dirigeants, managers et équipes à voir ce qui bloque, prendre des décisions utiles et transformer les échanges en actions concrètes.</p>

      <div class="hero-actions">
        <a href={withBase('/contact/')} class="btn">Parler de ce qui coince →</a>
        <a href={withBase('/#accompagnements')} class="btn-outline">Voir les accompagnements</a>
      </div>
      <p class="hero-pillars">Facilitation · Coaching · Séminaires · Transformation · Formation</p>
    </div>

    <div class="hero-loop" aria-hidden="true">
      <p class="loop-badge">Ça tourne en rond</p>

      <svg class="loop-svg" viewBox="0 0 600 520" preserveAspectRatio="xMidYMid meet">
        <path class="loop-track" d="M180 110 C 85 145, 70 270, 145 350 C 225 435, 370 415, 395 315 C 415 235, 335 130, 180 110" />
        <path class="exit-track" d="M395 315 C 450 335, 490 315, 525 270 C 555 230, 575 190, 600 145" />
        <circle class="loop-runner runner-1" r="9" />
        <circle class="loop-runner runner-2" r="6" />
      </svg>

      <div class="loop-center">
        <strong>On en reparle ?</strong>
        <small>Toujours la même réponse.</small>
      </div>

      <div class="break-point"><span>STOP</span></div>

      {loopCards.map((c, i) => (
        <article class:list={['loop-card', `loop-card-${i + 1}`]}>
          <strong>{c.t}</strong>
          <span>{c.s}</span>
        </article>
      ))}

      {exitCards.map((c, i) => (
        <article class:list={['exit-card', `exit-card-${i + 1}`]}>
          <strong>{c.t}</strong>
          <span>{c.s}</span>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const mm = gsap.matchMedia();

  // Seule animation JS de ce composant : la révélation du titre mot par
  // mot. Le diagramme "boucle qui se brise" plus bas est du CSS pur
  // (@keyframes) — un choix délibéré après avoir vérifié que les tweens
  // GSAP purement temporels (sans scroll) ne se comportaient pas de façon
  // fiable dans certains environnements : le CSS tourne sur son propre
  // thread de composition, sans dépendre du ticker JS.
  mm.add(
    { reduceMotion: '(prefers-reduced-motion: reduce)' },
    (context) => {
      const { reduceMotion } = context.conditions ?? {};
      const words = gsap.utils.toArray<HTMLElement>('[data-word]');

      if (reduceMotion) {
        gsap.set(words, { clearProps: 'all' });
      } else {
        gsap.set(words, { yPercent: 110, rotate: 6 });
        gsap.to(words, { yPercent: 0, rotate: 0, duration: 0.85, ease: 'power4.out', stagger: 0.045, delay: 0.1 });
      }

      return () => words.forEach((w) => gsap.killTweensOf(w));
    }
  );
</script>

<style>
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .hero-copy h1 {
    margin: var(--space-3) 0 var(--space-4);
  }

  .word-mask {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    padding-bottom: 0.08em;
  }
  .word-mask.is-highlight {
    background: var(--color-orange);
    padding: 0 0.12em 0.08em;
    border-radius: 2px;
  }
  .word {
    display: inline-block;
    will-change: transform;
  }

  .hero-lead {
    display: block;
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 46ch;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }
  .hero-pillars {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  /* --- Diagramme "boucle qui se brise" --- */
  .hero-loop {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 600 / 520;
    margin-inline: auto;
  }
  .loop-badge {
    position: absolute;
    top: 0;
    left: 4%;
    z-index: 4;
    margin: 0;
    background: var(--color-ink-solid);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.5em 0.8em;
    border-radius: var(--radius-sm);
    transform: rotate(-3deg);
  }

  .loop-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .loop-track {
    fill: none;
    stroke: var(--color-border);
    stroke-width: 3;
    stroke-dasharray: 9 9;
  }
  .exit-track {
    fill: none;
    stroke: var(--color-orange);
    stroke-width: 8;
    stroke-linecap: round;
    stroke-dasharray: 320;
    stroke-dashoffset: 320;
    animation: hero-loop-draw 5.5s ease-in-out infinite;
  }
  .loop-runner {
    fill: var(--color-clay);
    stroke: var(--color-surface);
    stroke-width: 3;
    offset-path: path("M180 110 C 85 145, 70 270, 145 350 C 225 435, 370 415, 395 315 C 415 235, 335 130, 180 110");
    offset-rotate: 0deg;
    animation: hero-loop-run 5.5s cubic-bezier(0.55, 0.02, 0.45, 0.98) infinite;
  }
  .runner-2 {
    fill: var(--color-orange);
    animation-delay: -1.6s;
    opacity: 0.9;
  }

  .loop-center {
    position: absolute;
    z-index: 3;
    top: 47%;
    left: 45%;
    width: 34%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border: 2px solid var(--color-ink);
    background: var(--color-surface);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-3);
    box-shadow: var(--shadow-md);
  }
  .loop-center strong {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
  }
  .loop-center small {
    margin-top: 0.35em;
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-weight: 600;
  }

  .break-point {
    position: absolute;
    z-index: 6;
    right: 14%;
    top: 55%;
    width: 56px;
    height: 56px;
    background: var(--color-clay);
    color: var(--color-white);
    border: 3px solid var(--color-surface);
    border-radius: 50%;
    display: grid;
    place-items: center;
    box-shadow: 0 0 0 2px var(--color-ink);
    transform: rotate(-8deg);
    animation: hero-loop-break-pulse 5.5s ease-in-out infinite;
  }
  .break-point span {
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.06em;
  }

  .loop-card,
  .exit-card {
    position: absolute;
    z-index: 3;
    width: 145px;
    background: var(--color-surface);
    border: 1px solid var(--color-ink);
    padding: var(--space-2) var(--space-3);
    box-shadow: 5px 5px 0 var(--color-ink);
    line-height: 1.15;
  }
  .loop-card strong,
  .exit-card strong {
    display: block;
    font-size: var(--text-sm);
  }
  .loop-card span,
  .exit-card span {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin-top: 0.2em;
  }
  .loop-card-1 {
    top: 6%;
    left: 24%;
    transform: rotate(3deg);
  }
  .loop-card-2 {
    top: 47%;
    right: 1%;
    transform: rotate(4deg);
  }
  .loop-card-3 {
    bottom: 8%;
    left: 15%;
    transform: rotate(-4deg);
  }

  .exit-card {
    z-index: 5;
    background: var(--color-orange);
    border-color: var(--color-ink-solid);
    color: var(--color-ink-solid);
    opacity: 0;
    transform: translateX(-16px) rotate(-2deg);
    animation: hero-loop-exit-in 5.5s ease-in-out infinite;
  }
  .exit-card span {
    color: color-mix(in srgb, var(--color-ink-solid) 75%, transparent);
  }
  .exit-card-1 {
    right: -4%;
    top: 30%;
    animation-delay: 0.15s;
  }
  .exit-card-2 {
    right: -6%;
    top: 10%;
    animation-delay: 0.38s;
  }

  @keyframes hero-loop-run {
    0% { offset-distance: 0%; opacity: 0; }
    8% { opacity: 1; }
    68% { offset-distance: 100%; opacity: 1; }
    74%, 100% { offset-distance: 100%; opacity: 0; }
  }
  @keyframes hero-loop-draw {
    0%, 62% { stroke-dashoffset: 320; opacity: 0; }
    68% { opacity: 1; }
    84%, 100% { stroke-dashoffset: 0; opacity: 1; }
  }
  @keyframes hero-loop-exit-in {
    0%, 69% { opacity: 0; transform: translateX(-16px) rotate(-2deg); }
    78%, 94% { opacity: 1; transform: translateX(0) rotate(-2deg); }
    100% { opacity: 0; transform: translateX(6px) rotate(-2deg); }
  }
  @keyframes hero-loop-break-pulse {
    0%, 58% { transform: rotate(-8deg) scale(0.9); }
    65%, 76% { transform: rotate(-8deg) scale(1.15); }
    100% { transform: rotate(-8deg) scale(0.9); }
  }

  @media (prefers-reduced-motion: reduce) {
    .loop-runner {
      display: none;
    }
    .exit-track {
      stroke-dashoffset: 0;
      opacity: 1;
      animation: none;
    }
    .exit-card {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .break-point {
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-loop {
      margin-top: var(--space-12);
      max-width: 460px;
    }
  }

  /* En dessous de 560px, le diagramme spatial (positions en %) fait se
     chevaucher les cartes — leur taille ne rétrécit pas aussi vite que le
     conteneur. Plutôt que de forcer, on recompose en liste verticale : le
     même récit (bloqué -> STOP -> débloqué), lu de haut en bas. */
  @media (max-width: 560px) {
    .hero-loop {
      aspect-ratio: auto;
      max-width: 360px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-3);
      padding-top: var(--space-10);
    }
    .loop-svg {
      display: none;
    }
    .loop-badge {
      position: static;
      transform: none;
      align-self: flex-start;
      order: 1;
    }
    .loop-center {
      position: static;
      transform: none;
      width: 200px;
      margin: var(--space-2) 0;
      order: 2;
    }
    .loop-card,
    .exit-card {
      position: static;
      transform: none !important;
      width: 100%;
      max-width: 280px;
      opacity: 1;
      animation: none;
      order: 3;
    }
    .break-point {
      position: static;
      transform: none;
      animation: none;
      margin: var(--space-2) 0;
      order: 4;
    }
    .exit-card {
      background: var(--color-orange);
      order: 5;
    }
  }
</style>
