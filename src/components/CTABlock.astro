---
import { SITE } from '../data/site';
import { withBase } from '../utils/url';

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="cta-block" data-reveal>
  <div class="cta-aura" aria-hidden="true"></div>
  <div class="container cta-inner">
    <h2>{title}</h2>
    {subtitle && <p class="prose">{subtitle}</p>}
    <div class="cta-actions">
      <a href={SITE.bookingUrl} class="btn" target="_blank" rel="noopener">Prendre rendez-vous</a>
      <a href={withBase('/contact/')} class="btn-outline">Envoyer un message</a>
    </div>
  </div>
</section>

<style>
  .cta-block {
    position: relative;
    background: var(--color-blue-strong);
    color: var(--color-white);
    overflow: hidden;
  }
  .cta-aura {
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 203, 0, 0.18), transparent 55%),
      radial-gradient(circle at 80% 70%, rgba(227, 67, 53, 0.1), transparent 45%);
    background-size: 140% 140%;
    animation: aura-drift 14s ease-in-out infinite;
    pointer-events: none;
  }
  .cta-inner {
    position: relative;
    text-align: center;
  }
  .cta-block h2 {
    color: var(--color-white);
  }
  .cta-block p {
    color: #d9d4c8;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }
  .cta-block .btn-outline {
    color: var(--color-white);
    box-shadow: inset 0 0 0 1.5px rgba(255, 255, 255, 0.6);
    background: transparent;
  }
  .cta-block .btn-outline:hover {
    background: var(--color-white);
    color: var(--color-ink-solid);
  }
</style>
