---
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-facilitation-workshop.png';
import { SITE } from '../data/site';
import { withBase } from '../utils/url';

const variants = [
  {
    title: 'Révéler le meilleur de votre collectif.',
    text: 'Les réponses sont souvent déjà présentes dans votre organisation. J\'aide les leaders à créer les conditions qui permettent aux idées d\'émerger, aux décisions d\'être prises et aux équipes de passer à l\'action.',
  },
  {
    title: 'Les réponses sont souvent déjà dans la salle.',
    text: 'Encore faut-il créer les conditions pour les faire émerger.',
  },
  {
    title: "Faire participer n'est pas perdre du temps.",
    text: "C'est construire l'engagement nécessaire à l'action.",
  },
  {
    title: "Quand tout semble prioritaire, plus rien ne l'est.",
    text: 'Retrouvez une vision commune, des priorités partagées et l\'énergie pour avancer.',
  },
  {
    title: 'Donner à voir ce qui compte vraiment.',
    text: "Parce qu'un collectif avance mieux lorsqu'il partage une même compréhension.",
  },
];
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <h1 id="hero-title">{variants[0].title}</h1>
      <p class="prose" id="hero-text">{variants[0].text}</p>
      <div class="hero-actions">
        <a href={SITE.bookingUrl} class="btn" target="_blank" rel="noopener">Prendre rendez-vous</a>
        <a href={withBase('/approche/')} class="btn-outline">Découvrir mon approche</a>
      </div>
    </div>
    <div class="hero-image">
      <Image src={heroImage} alt="Nicolas Verdot anime un atelier de facilitation devant une équipe, avec des post-it et un mur visuel dessiné" width={720} height={480} />
    </div>
  </div>
</section>

<script define:vars={{ variants }}>
  const titleEl = document.getElementById('hero-title');
  const textEl = document.getElementById('hero-text');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion && titleEl && textEl) {
    let index = 0;
    setInterval(() => {
      index = (index + 1) % variants.length;
      titleEl.style.opacity = '0';
      textEl.style.opacity = '0';
      setTimeout(() => {
        titleEl.textContent = variants[index].title;
        textEl.textContent = variants[index].text;
        titleEl.style.opacity = '1';
        textEl.style.opacity = '1';
      }, 250);
    }, 6000);
  }
</script>

<style>
  .hero {
    padding-top: var(--space-16);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  #hero-title,
  #hero-text {
    transition: opacity 0.25s ease;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }
  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-image {
      order: -1;
    }
  }
</style>
