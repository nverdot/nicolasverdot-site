---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import CTABlock from '../../components/CTABlock.astro';
import { withBase } from '../../utils/url';
import { formationGroups } from '../../data/formations';

const diff = [
  { title: 'Le visuel', text: 'Les concepts sont rendus visibles pour faciliter la compréhension.' },
  { title: 'La pratique', text: 'Les participants apprennent en expérimentant, pas en écoutant.' },
  { title: 'Le terrain', text: 'Les exercices sont reliés à leurs situations réelles.' },
  { title: 'La simplicité', text: "L'objectif n'est pas de complexifier, mais de rendre les outils utilisables." },
];

const audiences = [
  'Managers', 'Formateurs', 'Facilitateurs internes', 'Équipes RH', 'Chefs de projet',
  'Scrum Masters', 'Product Owners', 'Coachs', 'Associations', 'Collectivités', "Organismes de formation",
];

const faqs = [
  { q: 'Faut-il savoir dessiner pour la facilitation graphique ?', a: "Non. L'objectif n'est pas de devenir artiste, mais d'apprendre à utiliser des formes simples pour clarifier les idées." },
  { q: 'Peut-on adapter la formation à nos métiers ?', a: "Oui, c'est même recommandé. Le contenu et les exemples sont ajustés à votre contexte." },
  { q: 'Peut-on former des formateurs ?', a: "Oui. C'est un axe fort de l'activité : rendre les formations internes plus actives et engageantes." },
  { q: 'Peut-on construire un parcours sur plusieurs mois ?', a: 'Oui, plusieurs sessions peuvent être combinées pour accompagner la montée en compétences dans la durée.' },
];
---

<Layout
  title="Formations — by Nicolas Verdot"
  description="Formations concrètes en facilitation graphique, intelligence collective, animation, leader facilitateur, IA appliquée et pédagogie active pour développer les compétences collectives."
  path="/formations/"
>
  <PageHero
    eyebrow="Formations"
    title="Développer les compétences qui font avancer les collectifs"
    summary="Former ne consiste pas seulement à transmettre des connaissances : c'est permettre aux personnes de changer leurs pratiques. Les formations sont conçues comme des expériences — concrètes, participatives, visuelles et directement applicables sur le terrain."
    pills={['Sur devis', 'Intra ou inter-entreprises', 'Programme ajustable selon vos enjeux']}
  />

  <section class="section" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Ce qui rend ces formations différentes</p>
          <h2>Apprendre en faisant</h2>
        </div>
        <p>Les participants ne viennent pas écouter une méthode pendant plusieurs heures. Ils expérimentent, pratiquent, se trompent, ajustent et repartent avec des outils utilisables dès le lendemain.</p>
      </div>
      <div class="cards">
        {diff.map((d) => (
          <article class="card">
            <h3>{d.title}</h3>
            <p>{d.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt" data-reveal>
    <div class="container prose">
      <p class="eyebrow">Pour qui ?</p>
      <h2>Des formations pensées pour le collectif</h2>
      <div class="tool-tags">
        {audiences.map((a) => <span class="tool-tag">{a}</span>)}
      </div>
    </div>
  </section>

  {formationGroups.map((group) => (
    <section class="section formation-group" data-reveal>
      <div class="container">
        <p class="eyebrow">{group.universe}</p>
        <div class="formation-grid">
          {group.items.map((f) => (
            <article class="formation-card">
              <div class="formation-meta">
                <span>{f.level}</span>
                <span>{f.duration}</span>
              </div>
              <h3>{f.title}</h3>
              <p>{f.summary}</p>
              <span class="formation-format">{f.format}</span>
              <a class="card-link" href={withBase('/contact/')}>Nous en parler</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section alt" data-reveal>
    <div class="container prose">
      <p class="eyebrow">FAQ</p>
      <h2>Questions fréquentes</h2>
      <div class="faq">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABlock
    title="Et si vos équipes repartaient avec des outils qu'elles utilisent vraiment ?"
    subtitle="Parlons de votre besoin de formation : public, objectifs, format et calendrier."
  />
</Layout>

<style>
  .formation-group:nth-of-type(odd) {
    background: var(--color-surface);
  }
  .formation-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .formation-card {
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-5);
  }
  .formation-meta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }
  .formation-meta span {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-blue);
  }
  .formation-meta span:not(:last-child)::after {
    content: '·';
    margin-left: var(--space-2);
    color: var(--color-border);
  }
  .formation-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  .formation-card p {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-3);
  }
  .formation-format {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-faint);
    margin-bottom: var(--space-3);
  }
</style>
