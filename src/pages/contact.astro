---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
---

<Layout
  title={`Contact — ${SITE.name}`}
  description="Contactez BY Nicolas Verdot pour un accompagnement en coaching, formation ou facilitation d'ateliers sur la Côte d'Azur."
  path="/contact/"
>
  <section class="contact-hero">
    <h1>Contact</h1>
    <p class="lead">
      Une question, un projet ? Écrivez-moi via le formulaire ci-dessous, ou directement par
      email ou téléphone.
    </p>
  </section>

  <section class="contact-grid">
    <div>
      <ContactForm />
    </div>
    <aside class="contact-info">
      <h2>Coordonnées</h2>
      <p><a href={`mailto:${SITE.email}`}>{SITE.email}</a></p>
      <p><a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a></p>
      <p>Zones d'intervention : {SITE.areasServed.join(', ')}</p>
    </aside>
  </section>
</Layout>

<style>
  .contact-hero {
    padding-top: 3rem;
    max-width: 680px;
  }
  .lead {
    color: #444;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
  }
  .contact-info {
    background: #f7f7f5;
    border-radius: 10px;
    padding: 1.75rem;
  }
  .contact-info h2 {
    margin-top: 0;
    font-size: 1.1rem;
  }
  .contact-info a {
    color: #0a5c4a;
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
