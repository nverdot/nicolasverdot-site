---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';

const reasons = [
  'concevoir et animer un séminaire',
  'faciliter un atelier stratégique',
  'accompagner un CODIR',
  'animer une démarche participative',
  'réaliser une captation graphique',
  'former vos équipes',
  'accompagner des managers',
  'structurer une démarche d\'intelligence collective',
];

const prepQuestions = [
  'Qui est concerné ?',
  'Quel est le défi ?',
  "Qu'est-ce qui bloque ou patine ?",
  'Qu\'aimeriez-vous que les participants ressentent à la fin ?',
  'Quelle décision ou action doit émerger ?',
  'Quel est le calendrier ?',
  'Combien de personnes sont concernées ?',
];
---

<Layout
  title={`Contact — ${SITE.name}`}
  description="Contactez Nicolas Verdot pour parler de vos séminaires, ateliers, formations, accompagnements, captations graphiques ou projets d'intelligence collective."
  path="/contact/"
>
  <section class="contact-hero">
    <div class="container prose">
      <h1>Parlons de votre collectif.</h1>
      <p class="lead">
        Vous préparez un séminaire, une transformation, une démarche participative, une conférence,
        une formation ou un accompagnement de leaders ? Expliquez-moi simplement ce que vous avez en tête.
      </p>
    </div>
  </section>

  <section class="contact-grid-section" data-reveal>
    <div class="container contact-grid">
      <div>
        <ContactForm />
      </div>
      <aside class="contact-info panel">
        <h2>Coordonnées</h2>
        <p><a href={`mailto:${SITE.email}`}>{SITE.email}</a></p>
        <p><a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a></p>
        <p><a href={SITE.bookingUrl} target="_blank" rel="noopener">Prendre rendez-vous en ligne →</a></p>
        <p class="response-time">Je réponds généralement sous 48 heures ouvrées.</p>

        <h2>Vous pouvez me contacter pour</h2>
        <ul>
          {reasons.map((reason) => <li>{reason}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="prep" data-reveal>
    <div class="container prose">
      <h2>Avant notre échange</h2>
      <p>Pour préparer la discussion, vous pouvez déjà réfléchir à :</p>
      <ul>
        {prepQuestions.map((q) => <li>{q}</li>)}
      </ul>
      <p>Pas besoin d'avoir toutes les réponses — c'est justement le point de départ de notre conversation.</p>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    padding-bottom: 0;
  }
  .lead {
    color: var(--color-muted);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: var(--space-12);
    align-items: start;
  }
  .contact-info {
    padding: var(--space-6);
  }
  .contact-info h2 {
    font-size: var(--text-lg);
  }
  .contact-info a {
    color: var(--color-navy);
    text-decoration: none;
    font-weight: 600;
  }
  .response-time {
    font-size: var(--text-sm);
    color: var(--color-faint);
  }
  .prep {
    background: var(--color-surface);
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
