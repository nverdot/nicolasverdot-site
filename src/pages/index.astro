---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import OfferCard from '../components/OfferCard.astro';
import CTABlock from '../components/CTABlock.astro';
import { Image } from 'astro:assets';
import action from '../assets/nicolas-action.jpeg';
import { withBase } from '../utils/url';

const verbatims = [
  'Encore une transformation qui devient la priorité numéro 1 de toutes les priorités numéro 1.',
  "On a déjà fait trois ateliers. On sait ce qu'il faudrait faire. Maintenant, quelqu'un décide ?",
  'On appelle ça co-construction, mais les décisions importantes sont déjà prises.',
  "Tout le monde dit oui en réunion. Dans les couloirs, plus personne n'y croit vraiment.",
  'On sort avec des post-it partout. Lundi, personne ne sait quoi faire.',
  "On nous demande d'embarquer les équipes, mais le sens change toutes les deux semaines.",
];

const frictions = [
  { title: 'Beaucoup de réunions, peu de décisions', text: 'Les échanges avancent, puis les mêmes sujets reviennent au point de départ.' },
  { title: 'Toujours les mêmes voix', text: "Quelques personnes portent la parole, pendant que d'autres restent spectateurs." },
  { title: 'Des priorités qui se dispersent', text: 'Tout semble important, donc rien ne devient vraiment clair, partagé et actionnable.' },
  { title: 'Un élan qui retombe', text: "Le séminaire crée de l'énergie, mais le passage à l'action se dilue après quelques jours." },
];

const offers = [
  {
    icon: '◆',
    title: 'Décider ensemble',
    text: "Transformer un sujet complexe en décisions claires, comprises et assumées collectivement — quand les discussions tournent en rond et que les priorités restent floues.",
  },
  {
    icon: '◎',
    title: "Aligner l'équipe",
    text: 'Créer une direction commune et remettre le collectif en mouvement autour de priorités réellement partagées — l\'offre centrale, pour les séminaires qui doivent produire plus qu\'un bon souvenir.',
  },
  {
    icon: '⟳',
    title: 'Installer une dynamique durable',
    text: "Passer d'un moment d'alignement à une nouvelle manière de travailler, de décider et de responsabiliser les équipes, dans la durée.",
  },
];

const complementaryOffers = [
  'Diagnostic Leader Ancré', 'Mentorat Leader', "Conception d'événements",
  'Facilitation graphique', 'Formation professionnelle', 'Décoincés du Crayon',
];

const profilePoints = [
  { title: "Redonner de l'énergie", text: 'Des pratiques collectives qui remettent les personnes dans le jeu.' },
  { title: 'Rendre le sens visible', text: 'Des supports visuels pour clarifier ce qui se joue et ce qui compte.' },
  { title: 'Passer au faire', text: "Un cadre d'autonomie pour avancer sans que tout repose sur le leader." },
];

const audiences = ['Associations', 'PME', 'Grandes entreprises', 'Collectivités', 'Réseaux'];

const clients = [
  { name: 'Air France KLM', logo: '/logos/air-france-klm.png' },
  { name: 'Louis Vuitton', logo: '/logos/louis-vuitton.svg' },
  { name: 'PwC', logo: '/logos/pwc.webp' },
  { name: 'MG2Mix', logo: '/logos/mg2mix.png' },
  { name: 'Ressource SI', logo: '/logos/ressources.png' },
  { name: 'Mairie de Valbonne' },
  { name: 'JCI Monaco', logo: '/logos/jci-monaco.png' },
  { name: 'URSSAF', logo: '/logos/urssaf.webp' },
  { name: "Commune d'Angers" },
  { name: 'CAF Rhône-Alpes' },
  { name: 'CEC', logo: '/logos/cec.png' },
  { name: 'Fibois Sud' },
  { name: 'Osan We', logo: '/logos/osanwe.png' },
  { name: 'IA2P' },
  { name: 'MediaSchool' },
];
---

<Layout
  title="by Nicolas Verdot — Du collectif qui discute au collectif qui agit vraiment"
  description="Facilitation, séminaires, facilitation graphique, coaching, IA et formations pour aider les collectifs à clarifier, décider et passer à l'action."
  path="/"
>
  <Hero />

  <section class="whispers" data-reveal>
    <div class="container">
      <p class="eyebrow">Ce que les équipes pensent tout bas</p>
      <h2 class="prose">Les phrases qu'on entend dans les couloirs, jamais en réunion.</h2>
      <div class="verbatim-grid">
        {verbatims.map((v) => <blockquote>{v}</blockquote>)}
      </div>
    </div>
  </section>

  <section class="frictions" id="interventions" data-reveal>
    <div class="container">
      <p class="eyebrow">Là où j'interviens</p>
      <h2 class="prose">Vous ne manquez pas d'idées. Il vous manque une posture, des techniques, un cadre.</h2>
      <p class="prose">De quoi créer les conditions du passage à l'action. Voici les quatre blocages que je dénoue le plus souvent.</p>
      <div class="friction-grid">
        {frictions.map((f, i) => (
          <article class="friction-card card-brut">
            <span class="friction-number">{String(i + 1).padStart(2, '0')}</span>
            <strong>{f.title}</strong>
            <p>{f.text}</p>
          </article>
        ))}
      </div>
      <p class="friction-outcome"><strong>Mon rôle :</strong> tenir le cadre, rendre visible ce qui compte, faire contribuer les bonnes personnes, aider à décider et transformer l'énergie collective en prochaines actions assumées.</p>
    </div>
  </section>

  <section class="offers" id="accompagnements" data-reveal>
    <div class="container">
      <p class="eyebrow">Ce que je propose, concrètement</p>
      <h2 class="prose">Des temps collectifs qui produisent autre chose que des slides et de bonnes intentions.</h2>
      <p class="prose">Je ne viens pas avec des réponses toutes faites. Je conçois et j'anime le cadre qui permet à vos équipes de clarifier, contribuer, décider et repartir avec une suite réelle.</p>
      <div class="offer-grid">
        {offers.map((offer) => <OfferCard icon={offer.icon} title={offer.title} text={offer.text} />)}
      </div>
      <p class="complementary-label">Selon votre situation, ces offres peuvent aussi s'y ajouter :</p>
      <div class="complementary-tags">
        {complementaryOffers.map((c) => <span>{c}</span>)}
      </div>
    </div>
  </section>

  <section class="profile" data-reveal>
    <div class="container profile-grid">
      <div class="profile-photo">
        <Image src={action} alt="Nicolas Verdot en action pendant une captation graphique" width={480} height={560} />
        <p>Plus de 12 ans sur le terrain, au contact des collectifs.</p>
      </div>
      <div class="profile-copy">
        <p class="eyebrow">Qui je suis</p>
        <h2>Je suis Nicolas Verdot.</h2>
        <p class="profile-lead">Mon métier : booster les leaders et les équipes pour redonner du sens, de l'énergie et un cadre d'autonomie pour faire.</p>
        <p>Depuis plus de 12 ans, j'interviens aussi bien auprès d'associations que de PME, de collectivités ou de très grandes entreprises. Mon sujet n'est pas la taille de l'organisation : c'est le collectif au moment où il doit se parler, décider et agir.</p>
        <div class="audience-tags">
          {audiences.map((a) => <span>{a}</span>)}
        </div>
        <div class="profile-points">
          {profilePoints.map((p) => (
            <article>
              <strong>{p.title}</strong>
              <span>{p.text}</span>
            </article>
          ))}
        </div>
        <a href={withBase('/a-propos/')} class="profile-link">Découvrir mon parcours →</a>
      </div>
    </div>
  </section>

  <section class="trust" data-reveal>
    <div class="container">
      <p class="eyebrow center">Ils m'ont déjà fait confiance</p>
      <h2 class="prose center">Des contextes différents, un même enjeu : faire avancer le collectif.</h2>
    </div>
    <div class="client-marquee">
      <div class="client-marquee-track">
        {[...clients, ...clients].map((c, i) => (
          <span class="client-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
            {c.logo ? <img src={withBase(c.logo)} alt={c.name} loading="lazy" /> : <span class="client-text">{c.name}</span>}
          </span>
        ))}
      </div>
    </div>
  </section>

  <CTABlock
    title="30 minutes pour comprendre votre contexte et voir si je peux vous aider."
    subtitle="Réservez un échange pour clarifier votre besoin, votre projet ou votre prochain temps collectif. On identifie ensemble ce qui bloque ou ce qui doit émerger."
  />
</Layout>

<style>
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: var(--space-2);
  }
  .eyebrow.center {
    text-align: center;
  }
  .prose.center {
    max-width: var(--prose-max);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .whispers {
    background: var(--color-surface);
  }
  .verbatim-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8) var(--space-6);
    margin-top: var(--space-8);
  }
  .verbatim-grid blockquote {
    position: relative;
    margin: 0;
    padding: var(--space-8) var(--space-6) var(--space-6);
    background: var(--color-cream);
    border: 2.5px solid var(--color-navy);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-brut);
    font-style: italic;
    color: var(--color-muted);
    transition: transform var(--duration-standard) var(--ease-standard), box-shadow var(--duration-standard) var(--ease-standard);
  }
  .verbatim-grid blockquote:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-navy);
  }
  .verbatim-grid blockquote::before {
    content: '\201C';
    position: absolute;
    top: -0.2em;
    left: var(--space-4);
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 900;
    font-size: 3.5rem;
    line-height: 1;
    color: var(--color-orange);
  }
  .verbatim-grid blockquote::after {
    content: '';
    position: absolute;
    left: 28px;
    bottom: -12px;
    width: 22px;
    height: 22px;
    background: var(--color-cream);
    border-right: 2.5px solid var(--color-navy);
    border-bottom: 2.5px solid var(--color-navy);
    border-radius: 0 0 4px 0;
    transform: rotate(45deg);
  }

  .friction-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
    margin: var(--space-8) 0;
  }
  .friction-card {
    background: var(--color-surface);
    padding: var(--space-6);
  }
  .friction-number {
    display: block;
    font-family: var(--font-display);
    color: var(--color-border);
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }
  .friction-card strong {
    display: block;
    margin-bottom: var(--space-2);
  }
  .friction-card p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .friction-outcome {
    background: var(--color-blue-strong);
    color: var(--color-white);
    padding: var(--space-6);
    border-radius: var(--radius-md);
  }

  .offer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }
  .complementary-label {
    margin: var(--space-8) 0 var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .complementary-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .complementary-tags span {
    background: var(--color-cream);
    border: 1.5px solid var(--color-navy);
    border-radius: var(--radius-pill);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .profile {
    background: var(--color-surface);
  }
  .profile-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .profile-photo img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .profile-photo p {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-faint);
    text-align: center;
  }
  .profile-lead {
    font-size: var(--text-lg);
  }
  .audience-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-4) 0 var(--space-6);
  }
  .audience-tags span {
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-sm);
  }
  .profile-points {
    display: grid;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .profile-points strong {
    display: block;
    color: var(--color-navy);
  }
  .profile-points span {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .profile-link {
    font-weight: 600;
    color: var(--color-navy);
    text-decoration: none;
  }

  .client-marquee {
    margin-top: var(--space-8);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .client-marquee-track {
    display: flex;
    width: max-content;
    gap: var(--space-12);
    animation: marquee-scroll 28s linear infinite;
  }
  .client-marquee:hover .client-marquee-track {
    animation-play-state: paused;
  }
  .client-item {
    display: flex;
    align-items: center;
    height: 52px;
    flex-shrink: 0;
    background: var(--color-white);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
  }
  .client-item img {
    max-height: 100%;
    max-width: 130px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.6;
    transition: opacity var(--duration-standard) var(--ease-standard), filter var(--duration-standard) var(--ease-standard);
  }
  .client-marquee:hover .client-item img {
    filter: grayscale(0);
    opacity: 1;
  }
  .client-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-navy);
    opacity: 0.7;
    white-space: nowrap;
  }

  @media (max-width: 800px) {
    .profile-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
