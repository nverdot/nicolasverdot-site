---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Journey from '../components/Journey.astro';
import CTABlock from '../components/CTABlock.astro';
import { withBase } from '../utils/url';
import { conversations } from '../data/conversations';
import action from '../assets/nicolas-action.jpeg';
import { getCollection } from 'astro:content';

const latestArticles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
const articleDateFormatter = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

const faq = [
  {
    q: 'Comment se déroule un premier échange ?',
    a: "Un appel de 30 minutes, sans engagement, pour comprendre votre situation, le niveau de décision concerné et vérifier que mon intervention est pertinente. Vous repartez avec un avis clair, même si ce n'est pas moi qu'il vous faut.",
  },
  {
    q: 'Comment savoir quelle offre correspond à ma situation ?',
    a: "Vous n'avez pas à choisir seul : chaque porte d'entrée du site est pensée pour vous aider à reconnaître votre situation, avec un diagnostic pour vous situer. Le premier échange sert justement à confirmer ou ajuster ce choix.",
  },
  {
    q: 'Intervenez-vous uniquement dans les Alpes-Maritimes ?',
    a: 'Non. Je suis basé dans les Alpes-Maritimes, ce qui simplifie mes interventions à Nice, Cannes, Sophia Antipolis ou Monaco — mais j\'interviens partout en France pour des séminaires, ateliers et formations.',
  },
  {
    q: "Combien de temps à l'avance faut-il vous solliciter ?",
    a: 'Comptez trois à six semaines pour un séminaire ou un accompagnement, le temps de cadrer l\'intention et de préparer le format. Pour un atelier court, deux semaines peuvent suffire.',
  },
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const offers = [
  {
    num: '01 · Décider ensemble',
    title: '« On discute beaucoup. On décide peu. »',
    text: 'Un processus de décision qui transforme votre sujet complexe en choix clair, assumé et suivi d\'effets — dès la sortie de la salle.',
    cta: 'Débloquer la décision',
    href: withBase('/offres/decider-ensemble/'),
    ribbon: false,
  },
  {
    num: "02 · Aligner l'équipe",
    title: '« Chacun avance. Mais pas dans le même sens. »',
    text: 'Un temps fort pour construire une direction commune, traiter les divergences en face et remettre le collectif en mouvement.',
    cta: 'Retrouver un cap commun',
    href: withBase('/offres/aligner-equipe/'),
    ribbon: true,
  },
  {
    num: '03 · Dynamique durable',
    title: '« On répare toujours les mêmes pannes. »',
    text: "Faire évoluer la prise de décision, les responsabilités et les rituels — changer le système, pas poser des pansements.",
    cta: 'Installer une dynamique durable',
    href: withBase('/offres/dynamique-durable/'),
    ribbon: false,
  },
];

const whoChecks = [
  { i: '✓', title: 'Vous gardez la main', text: 'Le collectif enrichit la décision, il ne la prend pas à votre place. Vous restez décideur — en sachant enfin sur quoi vous appuyer.' },
  { i: '✓', title: 'Ça se voit tout de suite', text: 'Chaque échange est capturé et rendu visible en direct, grâce à la facilitation graphique. Personne ne repart en se demandant ce qui a été dit.' },
  { i: '✓', title: 'Vos équipes continuent sans moi', text: "Mon objectif n'est pas de revenir animer votre prochaine réunion. C'est que vous n'en ayez plus besoin." },
];

const recognizable = [
  "« On a fait un séminaire l'an dernier. Rien n'a vraiment changé. »",
  '« Le CODIR décide. Trois semaines après, tout se rediscute. »',
  '« Tout le monde est débordé. Personne ne sait dire pourquoi. »',
  '« La transformation est lancée. Le terrain ne suit pas. »',
];

const complementary = [
  { num: 'Transformation', title: '« La transfo est lancée. Le terrain ne suit pas. »', text: 'Débloquer les transformations IA, Agile ou culturelles qui restent sur le papier.', cta: "Remettre la transformation en mouvement", href: withBase('/offres/accompagnement-transformation/') },
  { num: 'Coaching professionnel', title: '« Je porte beaucoup. Et je le porte seul. »', text: 'Travailler la posture, les interactions et la sécurité intérieure du leader, en individuel.', cta: 'Découvrir le coaching', href: withBase('/offres/coaching-professionnel/') },
  { num: 'Capture graphique', title: '« Ce séminaire doit rester dans les mémoires. »', text: 'Une fresque visuelle réalisée en direct, qui capte vos échanges et prolonge leur impact bien après l\'événement.', cta: 'Voir la capture graphique', href: withBase('/offres/capture-graphique/') },
  { num: 'Formations', title: '« Nos managers animent comme ils peuvent. »', text: "Facilitation, intelligence collective, pensée visuelle, IA appliquée : des compétences qui restent dans l'équipe.", cta: 'Parcourir les formations', href: withBase('/formations/') },
];
const complementaryMore = ['Mentorat Leader', "Conception d'événements", 'Décoincés du Crayon'];

const clients = [
  { name: 'Air France KLM', logo: '/logos/air-france-klm.png' },
  { name: 'Louis Vuitton', logo: '/logos/louis-vuitton.svg' },
  { name: 'PwC', logo: '/logos/pwc.webp' },
  { name: 'MG2Mix', logo: '/logos/mg2mix.png' },
  { name: 'Ressource SI', logo: '/logos/ressources.png' },
  { name: 'Mairie de Valbonne' },
  { name: 'JCI Monaco', logo: '/logos/jci-monaco.png' },
  { name: 'URSSAF', logo: '/logos/urssaf.webp' },
  { name: "Commune d'Angers" },
  { name: 'CAF Rhône-Alpes' },
  { name: 'CEC', logo: '/logos/cec.png' },
  { name: 'Fibois Sud' },
  { name: 'Osan We', logo: '/logos/osanwe.png' },
  { name: 'IA2P' },
  { name: 'MediaSchool' },
];
---

<Layout
  title="Facilitateur professionnel, coach et formateur — by Nicolas Verdot"
  description="Séminaires facilités, ateliers d'intelligence collective, facilitation graphique, coaching et formations : trouvez le service qui débloquera votre équipe — et passez de la discussion à l'action."
  path="/"
>
  <Hero />

  <section class="trust" data-reveal>
    <div class="container">
      <p class="eyebrow center">Ils m'ont déjà fait confiance</p>
    </div>
    <div class="client-marquee">
      <div class="client-marquee-track">
        {[...clients, ...clients].map((c, i) => (
          <span class="client-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
            {c.logo ? <img src={withBase(c.logo)} alt={c.name} loading="lazy" /> : <span class="client-text">{c.name}</span>}
          </span>
        ))}
      </div>
    </div>
    <div class="container">
      <ul class="authority" aria-label="Repères de confiance">
        <li><a href={withBase('/facilitation-graphique/')}>Fondateur du Sommet des Décoincés du Crayon</a></li>
        <li><a href={withBase('/materiel/')}>Ambassadeur Neuland</a></li>
        <li><a href={withBase('/facilitation-graphique/')}>Un réseau national de facilitateurs mobilisable</a></li>
      </ul>
    </div>
  </section>

  <section class="recognize" data-reveal>
    <div class="container">
      <p class="eyebrow center">Vous reconnaissez peut-être...</p>
      <h2 class="prose center">Le symptôme n'est presque jamais celui qu'on croit.</h2>
      <ul class="recognize-list" data-recognize-list>
        {recognizable.map((r) => <li data-recognize-item>{r}</li>)}
      </ul>
    </div>
  </section>

  <Journey conversations={conversations} />

  <section class="offers" id="accompagnements" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Trois portes d'entrée</p>
          <h2>Commencez par votre problème, pas par nos méthodes.</h2>
        </div>
        <p>Vous n'avez pas besoin d'un catalogue de compétences : vous vivez une situation précise. Reconnaissez-la ci-dessous — chaque porte mène au service qui la traite, avec un diagnostic pour vous situer.</p>
      </div>
      <div class="cards">
        {offers.map((offer) => (
          <article class="card">
            {offer.ribbon && <div class="ribbon">CŒUR D'OFFRE</div>}
            <div class="num">{offer.num}</div>
            <h3>{offer.title}</h3>
            <p>{offer.text}</p>
            <a class="card-link" href={offer.href}>{offer.cta}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Votre situation est ailleurs ?</p>
          <h2>Elle a aussi sa porte.</h2>
        </div>
        <p>Transformation qui patine, dirigeant isolé, événement à marquer, compétences à ancrer : quatre autres façons de travailler ensemble.</p>
      </div>
      <div class="more-doors">
        {complementary.map((c) => (
          <a class="more-door" href={c.href}>
            <span class="more-door-num">{c.num}</span>
            <span class="more-door-title">{c.title}</span>
            <span class="more-door-cta">{c.cta} →</span>
          </a>
        ))}
      </div>
      <p class="complementary-label">Et aussi : {complementaryMore.join(' · ')}. <a href={withBase('/offres/')}>Voir toutes les offres</a> ou <a href={withBase('/facilitation-graphique/')}>découvrir la facilitation graphique</a>.</p>
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container split">
      <div>
        <p class="eyebrow">Qui suis-je ?</p>
        <h2>Un facilitateur qui relie structure, collectif et pensée visuelle.</h2>
        <p class="hero-copy">Ancien développeur, coach agile, facilitateur, formateur et moniteur de plongée, j'ai construit une approche qui combine clarté, responsabilité, participation utile et mise en action.</p>
        <div class="checks">
          {whoChecks.map((c) => (
            <div class="check"><i>{c.i}</i><div><strong>{c.title}</strong><br /><span class="muted">{c.text}</span></div></div>
          ))}
        </div>
        <div class="actions">
          <a class="btn" href={withBase('/a-propos/')}>Découvrir ma vision et mon approche</a>
        </div>
      </div>
      <div class="split-photo">
        <Image src={action} alt="Nicolas Verdot en pleine facilitation graphique" width={480} height={360} />
      </div>
    </div>
  </section>

  {latestArticles.length > 0 && (
    <section class="section" data-reveal>
      <div class="container">
        <div class="section-head">
          <div>
            <p class="eyebrow">Pour aller plus loin</p>
            <h2>Des situations concrètes, pas des recettes toutes faites.</h2>
          </div>
          <p>Décision, réunions, intelligence collective, culture d'équipe : les derniers articles du blog.</p>
        </div>
        <div class="cards insights-grid">
          {latestArticles.map((article) => (
            <article class="card insight-card">
              <div class="num">{article.data.pillar}</div>
              <h3><a href={withBase(`/blog/${article.slug}/`)}>{article.data.title}</a></h3>
              <div class="insight-date">{articleDateFormatter.format(article.data.publishDate)}</div>
              <p>{article.data.description}</p>
              <a class="card-link" href={withBase(`/blog/${article.slug}/`)}>Lire l'article</a>
            </article>
          ))}
        </div>
        <p class="complementary-label"><a href={withBase('/blog/')}>Voir tous les articles</a></p>
      </div>
    </section>
  )}

  <section class="section alt" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Questions fréquentes</p>
          <h2>Avant de nous appeler</h2>
        </div>
      </div>
      <div class="faq">
        {faq.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <CTABlock
    eyebrow="Un sujet à débloquer ?"
    title="Commençons par la situation réelle."
    subtitle="Un premier échange permet de comprendre l'enjeu, le niveau de décision et de vérifier si mon intervention est pertinente."
  />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  // Séquence scrollée (pin + scrub) : desktop uniquement, et seulement hors
  // reduced-motion — le repli est le simple fondu [data-reveal] déjà en
  // place partout ailleurs, donc rien à faire côté HTML/CSS pour ce cas.
  mm.add('(min-width: 900px) and (prefers-reduced-motion: no-preference)', () => {
    const section = document.querySelector<HTMLElement>('.recognize');
    const items = gsap.utils.toArray<HTMLElement>('[data-recognize-item]');
    if (!section || !items.length) return;

    gsap.set(items, { transformOrigin: 'center center' });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: '+=120%',
        scrub: 0.8,
        pin: true,
      },
    });

    items.forEach((item, i) => {
      tl.fromTo(
        item,
        { opacity: 0, scale: 0.7, y: 70, rotate: gsap.utils.random(-7, 7) },
        { opacity: 1, scale: 1, y: 0, rotate: 0, duration: 1, ease: 'power2.out' },
        i * 0.9
      );
    });

    return () => tl.scrollTrigger?.kill();
  });
</script>

<style>
  .eyebrow.center {
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }
  .prose.center {
    max-width: var(--prose-max);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .recognize {
    padding: var(--space-16) 0;
  }
  .recognize-list {
    list-style: none;
    margin: var(--space-10) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    max-width: 920px;
    margin-inline: auto;
  }
  .recognize-list li {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-clay);
    border-radius: var(--radius-sm);
    padding: var(--space-5) var(--space-6);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-navy);
  }
  @media (max-width: 720px) {
    .recognize-list {
      grid-template-columns: 1fr;
    }
  }

  .authority {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
    margin: var(--space-6) 0 0;
    padding: 0;
    font-size: var(--text-sm);
  }
  .authority li {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .authority li + li::before {
    content: '·';
    color: var(--color-orange);
    font-weight: 900;
  }
  .authority a {
    color: var(--color-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .authority a:hover {
    color: var(--color-ink);
    border-color: var(--color-orange);
  }

  .complementary-label {
    margin: var(--space-6) 0 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .complementary-label a {
    color: var(--color-blue);
    font-weight: 600;
  }

  /* Portes complémentaires : liste compacte plutôt que 4 cartes pleines —
     la homepage renvoie vers /offres/ pour le catalogue complet. */
  .more-doors {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .more-door {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    text-decoration: none;
    transition: transform var(--duration-hover) var(--ease-out), box-shadow var(--duration-hover) ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .more-door:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-sm);
    }
  }
  .more-door-num {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-green);
  }
  .more-door-title {
    font-weight: 700;
    color: var(--color-navy);
  }
  .more-door-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-blue);
  }
  @media (max-width: 680px) {
    .more-doors {
      grid-template-columns: 1fr;
    }
  }

  .insights-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .insight-date {
    font-size: var(--text-xs);
    color: var(--color-faint);
    margin: 0.2em 0 0.6em;
  }
  @media (max-width: 980px) {
    .insights-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 680px) {
    .insights-grid {
      grid-template-columns: 1fr;
    }
  }

  .client-marquee {
    margin-top: var(--space-8);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .client-marquee-track {
    display: flex;
    width: max-content;
    gap: var(--space-12);
    animation: marquee-scroll 28s linear infinite;
  }
  .client-marquee:hover .client-marquee-track {
    animation-play-state: paused;
  }
  .client-item {
    display: flex;
    align-items: center;
    height: 52px;
    flex-shrink: 0;
    background: var(--color-white);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
  }
  .client-item img {
    max-height: 100%;
    max-width: 130px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.6;
    transition: opacity var(--duration-standard) var(--ease-standard), filter var(--duration-standard) var(--ease-standard);
  }
  .client-marquee:hover .client-item img {
    filter: grayscale(0);
    opacity: 1;
  }
  .client-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-navy);
    opacity: 0.7;
    white-space: nowrap;
  }
</style>
