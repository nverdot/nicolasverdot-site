---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Journey from '../components/Journey.astro';
import CTABlock from '../components/CTABlock.astro';
import { withBase } from '../utils/url';
import { conversations } from '../data/conversations';
import action from '../assets/nicolas-action.jpeg';
import { getCollection } from 'astro:content';

const latestArticles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
const articleDateFormatter = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

const faq = [
  {
    q: 'Comment se déroule un premier échange ?',
    a: "Un appel de 30 minutes, sans engagement, pour comprendre votre situation, le niveau de décision concerné et vérifier que mon intervention est pertinente. Vous repartez avec un avis clair, même si ce n'est pas moi qu'il vous faut.",
  },
  {
    q: 'Comment savoir quelle offre correspond à ma situation ?',
    a: "Vous n'avez pas à choisir seul : chaque porte d'entrée du site est pensée pour vous aider à reconnaître votre situation, avec un diagnostic pour vous situer. Le premier échange sert justement à confirmer ou ajuster ce choix.",
  },
  {
    q: 'Intervenez-vous uniquement dans les Alpes-Maritimes ?',
    a: 'Non. Je suis basé dans les Alpes-Maritimes, ce qui simplifie mes interventions à Nice, Cannes, Sophia Antipolis ou Monaco — mais j\'interviens partout en France pour des séminaires, ateliers et formations.',
  },
  {
    q: "Combien de temps à l'avance faut-il vous solliciter ?",
    a: 'Comptez trois à six semaines pour un séminaire ou un accompagnement, le temps de cadrer l\'intention et de préparer le format. Pour un atelier court, deux semaines peuvent suffire.',
  },
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Convention icônes du site : traits feutre currentColor, viewBox 24×24
// (mêmes tracés que Footer.astro, pour rester cohérent d'une section à l'autre).
const icons: Record<string, string> = {
  bulb: '<path d="M9 18h6M10 21h4"/><path d="M12 3a6 6 0 0 0-3 11.2c.6.4 1 1.1 1 1.8h4c0-.7.4-1.1 1-1.8A6 6 0 0 0 12 3z"/>',
  check: '<circle cx="12" cy="12" r="9"/><path d="M8 12l3 3 5-6"/>',
  people: '<circle cx="8" cy="8" r="3"/><path d="M2 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17" cy="9" r="2.5"/><path d="M14.5 20c.2-2.6 2.1-4.7 4.6-5"/>',
  trending: '<path d="M3 17l6-6 4 4 8-8"/><path d="M15 7h6v6"/>',
  grid: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>',
  user: '<circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>',
  pencil: '<path d="M3 21l3.5-1 11-11-2.5-2.5-11 11z"/><path d="M14 6.5l2.5 2.5"/>',
  cap: '<path d="M12 3 2 8l10 5 10-5-10-5z"/><path d="M6 11v5c0 1.7 2.7 3 6 3s6-1.3 6-3v-5"/>',
};

// Ce que change un accompagnement — pas de chiffre ni de témoignage inventés :
// le "+ de 15" du hero est le compte réel du bandeau de logos clients ci-dessous.
const proofItems = [
  { icon: 'bulb', title: 'Plus de clarté', text: "sur l'essentiel" },
  { icon: 'check', title: 'Des décisions plus rapides', text: 'et partagées' },
  { icon: 'people', title: 'Des équipes engagées', text: 'et alignées' },
  { icon: 'trending', title: 'Des actions qui produisent', text: 'vraiment des résultats' },
];

const offerTiles = [
  { icon: 'grid', title: 'Séminaires et ateliers', text: 'Concevoir et animer des temps collectifs qui font avancer.', href: withBase('/offres/') },
  { icon: 'user', title: 'Coaching et mentoring', text: "Prendre du recul, renforcer sa posture, passer à l'action.", href: withBase('/offres/coaching-professionnel/') },
  { icon: 'trending', title: 'Transformation des organisations', text: 'Accompagner les changements qui engagent, avec clarté.', href: withBase('/offres/accompagnement-transformation/') },
  { icon: 'pencil', title: 'Capture graphique', text: "Rendre visible l'essentiel en temps réel.", href: withBase('/offres/capture-graphique/') },
  { icon: 'cap', title: 'Formations à la facilitation', text: 'Développer vos compétences pour animer autrement.', href: withBase('/formations/') },
];

const whoChecks = [
  { i: '✓', title: 'Vous gardez la main', text: 'Le collectif enrichit la décision, il ne la prend pas à votre place. Vous restez décideur — en sachant enfin sur quoi vous appuyer.' },
  { i: '✓', title: 'Ça se voit tout de suite', text: 'Chaque échange est capturé et rendu visible en direct, grâce à la facilitation graphique. Personne ne repart en se demandant ce qui a été dit.' },
  { i: '✓', title: 'Vos équipes continuent sans moi', text: "Mon objectif n'est pas de revenir animer votre prochaine réunion. C'est que vous n'en ayez plus besoin." },
];

const recognizable = [
  "« On a fait un séminaire l'an dernier. Rien n'a vraiment changé. »",
  '« Le CODIR décide. Trois semaines après, tout se rediscute. »',
  '« Tout le monde est débordé. Personne ne sait dire pourquoi. »',
  '« La transformation est lancée. Le terrain ne suit pas. »',
];

const clients = [
  { name: 'Air France KLM', logo: '/logos/air-france-klm.png' },
  { name: 'Louis Vuitton', logo: '/logos/louis-vuitton.svg' },
  { name: 'PwC', logo: '/logos/pwc.webp' },
  { name: 'MG2Mix', logo: '/logos/mg2mix.png' },
  { name: 'Ressource SI', logo: '/logos/ressources.png' },
  { name: 'Mairie de Valbonne' },
  { name: 'JCI Monaco', logo: '/logos/jci-monaco.png' },
  { name: 'URSSAF', logo: '/logos/urssaf.webp' },
  { name: "Commune d'Angers" },
  { name: 'CAF Rhône-Alpes' },
  { name: 'CEC', logo: '/logos/cec.png' },
  { name: 'Fibois Sud' },
  { name: 'Osan We', logo: '/logos/osanwe.png' },
  { name: 'IA2P' },
  { name: 'MediaSchool' },
];
---

<Layout
  title="Facilitateur professionnel, coach et formateur — by Nicolas Verdot"
  description="Séminaires facilités, ateliers d'intelligence collective, facilitation graphique, coaching et formations : trouvez le service qui débloquera votre équipe — et passez de la discussion à l'action."
  path="/"
>
  <Hero />

  <section class="proof-band" data-reveal data-section-name="Bénéfices">
    <div class="container proof-inner">
      <h2>
        Quand c'est plus clair,
        <span class="accent-wrap">
          tout avance.
          <svg class="ink-underline" viewBox="0 0 300 16" preserveAspectRatio="none" aria-hidden="true"><path d="M4 10 C 70 2, 150 14, 296 6" /></svg>
        </span>
      </h2>
      <div class="proof-grid">
        {proofItems.map((p) => (
          <div class="proof-item">
            <svg class="proof-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[p.icon]} />
            <p><strong>{p.title}</strong> {p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="trust" data-reveal data-section-name="Logos clients">
    <div class="client-marquee">
      <div class="client-marquee-track">
        {[...clients, ...clients].map((c, i) => (
          <span class="client-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
            {c.logo ? <img src={withBase(c.logo)} alt={c.name} loading="lazy" /> : <span class="client-text">{c.name}</span>}
          </span>
        ))}
      </div>
    </div>
    <div class="container">
      <ul class="authority" aria-label="Repères de confiance">
        <li><a href={withBase('/facilitation-graphique/')}>Fondateur du Sommet des Décoincés du Crayon</a></li>
        <li><a href={withBase('/materiel/')}>Ambassadeur Neuland</a></li>
        <li><a href={withBase('/facilitation-graphique/')}>Un réseau national de facilitateurs mobilisable</a></li>
      </ul>
    </div>
  </section>

  <section class="recognize" data-reveal data-section-name="Situations reconnaissables">
    <div class="container">
      <p class="eyebrow center">Vous reconnaissez peut-être...</p>
      <h2 class="prose center">Le symptôme n'est presque jamais celui qu'on croit.</h2>
      <ul class="recognize-list" data-recognize-list>
        {recognizable.map((r) => <li data-recognize-item>{r}</li>)}
      </ul>
    </div>
  </section>

  <Journey conversations={conversations} />

  <section class="section" id="accompagnements" data-reveal data-section-name="Offres principales">
    <div class="container">
      <div class="section-head">
        <h2>Des accompagnements <span class="circled">concrets<svg class="circle-mark" viewBox="0 0 160 60" preserveAspectRatio="none" aria-hidden="true"><path d="M12 30c-2-16 20-25 68-25s78 10 76 27-32 24-78 24S14 46 12 30z" /></svg></span> pour chaque étape clé</h2>
      </div>
      <div class="offer-grid">
        {offerTiles.map((o) => (
          <a class="offer-tile" href={o.href}>
            <svg class="offer-tile-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[o.icon]} />
            <h3>{o.title}</h3>
            <p>{o.text}</p>
            <span class="card-link">En savoir plus →</span>
          </a>
        ))}
      </div>
      <p class="complementary-label"><a href={withBase('/offres/')}>Voir toutes les offres</a> ou <a href={withBase('/facilitation-graphique/')}>découvrir la facilitation graphique</a>.</p>
    </div>
  </section>

  <section class="section" data-reveal data-section-name="Qui suis-je">
    <div class="container split">
      <div>
        <p class="eyebrow">Qui suis-je ?</p>
        <h2>Un facilitateur qui relie structure, collectif et pensée visuelle.</h2>
        <p class="hero-copy">Ancien développeur, coach agile, facilitateur, formateur et moniteur de plongée, j'ai construit une approche qui combine clarté, responsabilité, participation utile et mise en action.</p>
        <div class="checks">
          {whoChecks.map((c) => (
            <div class="check"><i>{c.i}</i><div><strong>{c.title}</strong><br /><span class="muted">{c.text}</span></div></div>
          ))}
        </div>
        <div class="actions">
          <a class="btn" href={withBase('/a-propos/')}>Découvrir ma vision et mon approche</a>
        </div>
      </div>
      <div class="split-photo">
        <Image src={action} alt="Nicolas Verdot en pleine facilitation graphique" width={480} height={360} />
      </div>
    </div>
  </section>

  {latestArticles.length > 0 && (
    <section class="section" data-reveal data-section-name="Articles du blog">
      <div class="container">
        <div class="section-head">
          <div>
            <p class="eyebrow">Pour aller plus loin</p>
            <h2>Des situations concrètes, pas des recettes toutes faites.</h2>
          </div>
          <p>Décision, réunions, intelligence collective, culture d'équipe : les derniers articles du blog.</p>
        </div>
        <div class="cards insights-grid">
          {latestArticles.map((article) => (
            <article class="card insight-card">
              <div class="num">{article.data.pillar}</div>
              <h3><a href={withBase(`/blog/${article.slug}/`)}>{article.data.title}</a></h3>
              <div class="insight-date">{articleDateFormatter.format(article.data.publishDate)}</div>
              <p>{article.data.description}</p>
              <a class="card-link" href={withBase(`/blog/${article.slug}/`)}>Lire l'article</a>
            </article>
          ))}
        </div>
        <p class="complementary-label"><a href={withBase('/blog/')}>Voir tous les articles</a></p>
      </div>
    </section>
  )}

  <section class="section alt" data-reveal data-section-name="FAQ">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Questions fréquentes</p>
          <h2>Avant de nous appeler</h2>
        </div>
      </div>
      <div class="faq">
        {faq.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <CTABlock
    eyebrow="Un sujet à débloquer ?"
    title="Commençons par la situation réelle."
    subtitle="Un premier échange permet de comprendre l'enjeu, le niveau de décision et de vérifier si mon intervention est pertinente."
  />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  // Séquence scrollée (pin + scrub) : desktop uniquement, et seulement hors
  // reduced-motion — le repli est le simple fondu [data-reveal] déjà en
  // place partout ailleurs, donc rien à faire côté HTML/CSS pour ce cas.
  mm.add('(min-width: 900px) and (prefers-reduced-motion: no-preference)', () => {
    const section = document.querySelector<HTMLElement>('.recognize');
    const items = gsap.utils.toArray<HTMLElement>('[data-recognize-item]');
    if (!section || !items.length) return;

    gsap.set(items, { transformOrigin: 'center center' });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: '+=120%',
        scrub: 0.8,
        pin: true,
      },
    });

    items.forEach((item, i) => {
      tl.fromTo(
        item,
        { opacity: 0, scale: 0.7, y: 70, rotate: gsap.utils.random(-7, 7) },
        { opacity: 1, scale: 1, y: 0, rotate: 0, duration: 1, ease: 'power2.out' },
        i * 0.9
      );
    });

    return () => tl.scrollTrigger?.kill();
  });
</script>

<style>
  .eyebrow.center {
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }
  .prose.center {
    max-width: var(--prose-max);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .recognize {
    padding: var(--space-16) 0;
  }
  .recognize-list {
    list-style: none;
    margin: var(--space-10) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    max-width: 920px;
    margin-inline: auto;
  }
  .recognize-list li {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-clay);
    border-radius: var(--radius-sm);
    padding: var(--space-5) var(--space-6);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-navy);
  }
  @media (max-width: 720px) {
    .recognize-list {
      grid-template-columns: 1fr;
    }
  }

  .authority {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
    margin: var(--space-6) 0 0;
    padding: 0;
    font-size: var(--text-sm);
  }
  .authority li {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .authority li + li::before {
    content: '·';
    color: var(--color-orange);
    font-weight: 900;
  }
  .authority a {
    color: var(--color-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .authority a:hover {
    color: var(--color-ink);
    border-color: var(--color-orange);
  }

  .complementary-label {
    margin: var(--space-6) 0 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .complementary-label a {
    color: var(--color-blue);
    font-weight: 600;
  }

  /* --- Bandeau noir "preuve" (4 bénéfices) --- */
  .proof-band {
    background: var(--color-ink-solid);
    color: var(--color-white);
    padding: var(--space-12) 0;
  }
  .proof-inner {
    text-align: center;
  }
  .proof-inner h2 {
    color: var(--color-white);
    margin: 0 0 var(--space-8);
  }
  .proof-inner .accent-wrap {
    display: inline-block;
    position: relative;
  }
  .proof-inner .ink-underline {
    position: absolute;
    left: 0;
    bottom: -0.15em;
    width: 100%;
    height: 0.25em;
    stroke: var(--color-orange);
    stroke-width: 5;
    fill: none;
  }
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-6);
    max-width: 1040px;
    margin-inline: auto;
  }
  .proof-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: 0 var(--space-2);
    border-left: 1px solid rgba(255, 255, 255, 0.15);
  }
  .proof-item:first-child {
    border-left: none;
  }
  .proof-icon {
    width: 28px;
    height: 28px;
    color: var(--color-orange);
  }
  .proof-item p {
    margin: 0;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.8);
  }
  .proof-item strong {
    display: block;
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: var(--text-base);
  }
  @media (max-width: 800px) {
    .proof-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8) var(--space-4);
    }
    .proof-item {
      border-left: none;
    }
  }

  /* --- "concrets" cerclé au feutre --- */
  .circled {
    position: relative;
    display: inline-block;
  }
  .circle-mark {
    position: absolute;
    inset: -0.3em -0.25em;
    width: calc(100% + 0.5em);
    height: calc(100% + 0.6em);
    stroke: var(--color-orange);
    stroke-width: 4;
    fill: none;
  }

  /* --- Grille des 5 accompagnements --- */
  .offer-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .offer-tile {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    text-decoration: none;
    transition: transform var(--duration-hover) var(--ease-out), box-shadow var(--duration-hover) ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .offer-tile:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-sm);
    }
  }
  .offer-tile-icon {
    width: 32px;
    height: 32px;
    color: var(--color-orange-ink);
    margin-bottom: var(--space-2);
  }
  .offer-tile h3 {
    margin: 0;
    font-size: var(--text-lg);
  }
  .offer-tile p {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--text-sm);
  }
  .offer-tile .card-link {
    margin-top: auto;
    padding-top: var(--space-2);
  }
  @media (max-width: 1000px) {
    .offer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .offer-grid {
      grid-template-columns: 1fr;
    }
  }

  .insights-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .insight-date {
    font-size: var(--text-xs);
    color: var(--color-faint);
    margin: 0.2em 0 0.6em;
  }
  @media (max-width: 980px) {
    .insights-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 680px) {
    .insights-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Bandeau de logos resserré : sans étiquette "Ils m'ont fait confiance"
     au-dessus, c'est déjà lisible comme preuve sociale — inutile de l'entourer
     d'autant de vide que les autres sections. */
  .trust {
    padding: var(--space-8) 0;
  }
  .client-marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .client-marquee-track {
    display: flex;
    width: max-content;
    gap: var(--space-12);
    animation: marquee-scroll 28s linear infinite;
  }
  .client-marquee:hover .client-marquee-track {
    animation-play-state: paused;
  }
  .client-item {
    display: flex;
    align-items: center;
    height: 52px;
    flex-shrink: 0;
    background: var(--color-white);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
  }
  .client-item img {
    max-height: 100%;
    max-width: 130px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.6;
    transition: opacity var(--duration-standard) var(--ease-standard), filter var(--duration-standard) var(--ease-standard);
  }
  .client-marquee:hover .client-item img {
    filter: grayscale(0);
    opacity: 1;
  }
  .client-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-navy);
    opacity: 0.7;
    white-space: nowrap;
  }
</style>
