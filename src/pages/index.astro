---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ChatCarousel from '../components/ChatCarousel.astro';
import CTABlock from '../components/CTABlock.astro';
import { withBase } from '../utils/url';
import { conversations } from '../data/conversations';
import action from '../assets/nicolas-action.jpeg';

const offers = [
  {
    num: '01 · Décider ensemble',
    title: '« On discute beaucoup. On décide peu. »',
    text: 'Un processus de décision qui transforme votre sujet complexe en choix clair, assumé et suivi d\'effets — dès la sortie de la salle.',
    cta: 'Débloquer la décision',
    href: withBase('/offres/decider-ensemble/'),
    ribbon: false,
  },
  {
    num: "02 · Aligner l'équipe",
    title: '« Chacun avance. Mais pas dans le même sens. »',
    text: 'Un temps fort pour construire une direction commune, traiter les divergences en face et remettre le collectif en mouvement.',
    cta: 'Retrouver un cap commun',
    href: withBase('/offres/aligner-equipe/'),
    ribbon: true,
  },
  {
    num: '03 · Dynamique durable',
    title: '« On répare toujours les mêmes pannes. »',
    text: "Faire évoluer la prise de décision, les responsabilités et les rituels — changer le système, pas poser des pansements.",
    cta: 'Installer une dynamique durable',
    href: withBase('/offres/dynamique-durable/'),
    ribbon: false,
  },
];

const doChecks = [
  { i: '1', title: "Cadrer l'enjeu", text: 'Que faut-il comprendre, traiter ou décider ?' },
  { i: '2', title: 'Concevoir le processus', text: 'Qui contribue, à quel moment, avec quelles limites ?' },
  { i: '3', title: 'Faciliter et rendre visible', text: 'Faire émerger, structurer, arbitrer et garder une trace.' },
  { i: '4', title: 'Préparer la suite', text: 'Responsables, décisions, feuille de route et suivi.' },
];

const whoChecks = [
  { i: 'V', title: 'Une vision', text: 'Des organisations où les personnes savent ce qui compte et dans quel cadre agir.' },
  { i: 'M', title: 'Une mission', text: 'Concevoir de meilleures conversations pour produire de meilleures décisions.' },
  { i: 'A', title: 'Une approche', text: 'Partir du résultat attendu avant de choisir les méthodes et les outils.' },
];

const method = [
  { title: 'Donner à voir', text: 'Clarifier les enjeux et rendre visibles les idées, les défis et les opportunités.' },
  { title: 'Faire participer', text: "Faire émerger l'intelligence collective et créer les conditions de l'engagement." },
  { title: 'Décider', text: 'Transformer les échanges en choix concrets. Prioriser. Aligner les énergies.' },
  { title: 'Agir', text: 'Passer des intentions aux actions et construire un plan réaliste et mobilisateur.' },
  { title: 'Apprendre', text: 'Observer, ajuster et progresser ensemble.' },
];

const complementary = [
  { num: 'Transformation', title: '« La transfo est lancée. Le terrain ne suit pas. »', text: 'Débloquer les transformations IA, Agile ou culturelles qui restent sur le papier.', cta: "Remettre la transformation en mouvement", href: withBase('/offres/accompagnement-transformation/') },
  { num: 'Coaching professionnel', title: '« Je porte beaucoup. Et je le porte seul. »', text: 'Travailler la posture, les interactions et la sécurité intérieure du leader, en individuel.', cta: 'Découvrir le coaching', href: withBase('/offres/coaching-professionnel/') },
  { num: 'Capture graphique', title: '« Ce séminaire doit rester dans les mémoires. »', text: 'Une fresque visuelle réalisée en direct, qui capte vos échanges et prolonge leur impact bien après l\'événement.', cta: 'Voir la capture graphique', href: withBase('/offres/capture-graphique/') },
  { num: 'Formations', title: '« Nos managers animent comme ils peuvent. »', text: "Facilitation, intelligence collective, pensée visuelle, IA appliquée : des compétences qui restent dans l'équipe.", cta: 'Parcourir les formations', href: withBase('/formations/') },
];
const complementaryMore = ['Mentorat Leader', "Conception d'événements", 'Décoincés du Crayon'];

const clients = [
  { name: 'Air France KLM', logo: '/logos/air-france-klm.png' },
  { name: 'Louis Vuitton', logo: '/logos/louis-vuitton.svg' },
  { name: 'PwC', logo: '/logos/pwc.webp' },
  { name: 'MG2Mix', logo: '/logos/mg2mix.png' },
  { name: 'Ressource SI', logo: '/logos/ressources.png' },
  { name: 'Mairie de Valbonne' },
  { name: 'JCI Monaco', logo: '/logos/jci-monaco.png' },
  { name: 'URSSAF', logo: '/logos/urssaf.webp' },
  { name: "Commune d'Angers" },
  { name: 'CAF Rhône-Alpes' },
  { name: 'CEC', logo: '/logos/cec.png' },
  { name: 'Fibois Sud' },
  { name: 'Osan We', logo: '/logos/osanwe.png' },
  { name: 'IA2P' },
  { name: 'MediaSchool' },
];
---

<Layout
  title="Facilitateur professionnel, coach et formateur — by Nicolas Verdot"
  description="Séminaires facilités, ateliers d'intelligence collective, facilitation graphique, coaching et formations : trouvez le service qui débloquera votre équipe — et passez de la discussion à l'action."
  path="/"
>
  <Hero />

  <section class="trust" data-reveal>
    <div class="container">
      <p class="eyebrow center">Ils m'ont déjà fait confiance</p>
    </div>
    <div class="client-marquee">
      <div class="client-marquee-track">
        {[...clients, ...clients].map((c, i) => (
          <span class="client-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
            {c.logo ? <img src={withBase(c.logo)} alt={c.name} loading="lazy" /> : <span class="client-text">{c.name}</span>}
          </span>
        ))}
      </div>
    </div>
    <div class="container">
      <ul class="authority" aria-label="Repères de confiance">
        <li><a href={withBase('/facilitation-graphique/')}>Fondateur du Sommet des Décoincés du Crayon</a></li>
        <li><a href={withBase('/materiel/')}>Ambassadeur Neuland</a></li>
        <li><a href={withBase('/facilitation-graphique/')}>Un réseau national de facilitateurs mobilisable</a></li>
      </ul>
    </div>
  </section>

  <section class="whispers" data-reveal>
    <div class="container">
      <p class="eyebrow">Ce qui se dit vraiment</p>
      <h2 class="prose">Ce que les équipes se disent <span class="marker">réellement</span> entre elles.</h2>
      <p class="prose whispers-lead">Jamais en réunion. Toujours juste après, entre deux portes ou dans un message privé. Si ces conversations vous rappellent quelque chose, la suite est pour vous.</p>
      <ChatCarousel conversations={conversations} />
    </div>
  </section>

  <section class="offers" id="accompagnements" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Trois portes d'entrée</p>
          <h2>Commencez par votre problème, pas par nos méthodes.</h2>
        </div>
        <p>Vous n'avez pas besoin d'un catalogue de compétences : vous vivez une situation précise. Reconnaissez-la ci-dessous — chaque porte mène au service qui la traite, avec un diagnostic pour vous situer.</p>
      </div>
      <div class="cards">
        {offers.map((offer) => (
          <article class="card">
            {offer.ribbon && <div class="ribbon">CŒUR D'OFFRE</div>}
            <div class="num">{offer.num}</div>
            <h3>{offer.title}</h3>
            <p>{offer.text}</p>
            <a class="card-link" href={offer.href}>{offer.cta}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Votre situation est ailleurs ?</p>
          <h2>Elle a aussi sa porte.</h2>
        </div>
        <p>Transformation qui patine, dirigeant isolé, événement à marquer, compétences à ancrer : quatre autres façons de travailler ensemble.</p>
      </div>
      <div class="cards">
        {complementary.map((c) => (
          <article class="card">
            <div class="num">{c.num}</div>
            <h3>{c.title}</h3>
            <p>{c.text}</p>
            <a class="card-link" href={c.href}>{c.cta}</a>
          </article>
        ))}
      </div>
      <p class="complementary-label">Et aussi : {complementaryMore.join(' · ')}. Curieux de la pensée visuelle ? <a href={withBase('/facilitation-graphique/')}>Découvrez ce qu'est la facilitation graphique</a>.</p>
    </div>
  </section>

  <section class="section alt" data-reveal>
    <div class="container split">
      <div>
        <p class="eyebrow">Ce que je fais réellement</p>
        <h2>Je ne viens pas seulement animer une salle.</h2>
        <p class="hero-copy">Le travail commence avant : clarifier l'intention, comprendre le système, identifier le niveau réel de participation et concevoir la conversation qui permettra d'obtenir un résultat exploitable.</p>
        <div class="checks">
          {doChecks.map((c) => (
            <div class="check"><i>{c.i}</i><div><strong>{c.title}</strong><br /><span class="muted">{c.text}</span></div></div>
          ))}
        </div>
      </div>
      <div class="quote">
        <blockquote>Un bon séminaire ne se mesure pas au nombre de post-it. Il se mesure à ce qui devient plus clair après.</blockquote>
        <cite>Nicolas Verdot — Facilitateur, coach et formateur</cite>
      </div>
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container split">
      <div>
        <p class="eyebrow">Qui suis-je ?</p>
        <h2>Un facilitateur qui relie structure, collectif et pensée visuelle.</h2>
        <p class="hero-copy">Ancien développeur, coach agile, facilitateur, formateur et moniteur de plongée, j'ai construit une approche qui combine clarté, responsabilité, participation utile et mise en action.</p>
        <div class="checks">
          {whoChecks.map((c) => (
            <div class="check"><i>{c.i}</i><div><strong>{c.title}</strong><br /><span class="muted">{c.text}</span></div></div>
          ))}
        </div>
        <div class="actions">
          <a class="btn" href={withBase('/a-propos/')}>Découvrir ma vision et mon approche</a>
        </div>
      </div>
      <div class="split-photo">
        <Image src={action} alt="Nicolas Verdot en pleine facilitation graphique" width={480} height={360} />
      </div>
    </div>
  </section>

  <section class="section dark" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">La méthode</p>
          <h2>Un processus simple, jamais simpliste.</h2>
        </div>
        <p>Les méthodes changent selon le contexte. Les étapes, elles, restent lisibles.</p>
      </div>
      <div class="method">
        {method.map((m, i) => (
          <div class="step"><b>{String(i + 1).padStart(2, '0')}</b>{m.title} — {m.text}</div>
        ))}
      </div>
    </div>
  </section>

  <CTABlock
    eyebrow="Un sujet à débloquer ?"
    title="Commençons par la situation réelle."
    subtitle="Un premier échange permet de comprendre l'enjeu, le niveau de décision et de vérifier si mon intervention est pertinente."
  />
</Layout>

<style>
  .eyebrow.center {
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }
  .prose.center {
    max-width: var(--prose-max);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .whispers {
    background: var(--color-surface);
  }

  .authority {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
    margin: var(--space-6) 0 0;
    padding: 0;
    font-size: var(--text-sm);
  }
  .authority li {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .authority li + li::before {
    content: '·';
    color: var(--color-orange);
    font-weight: 900;
  }
  .authority a {
    color: var(--color-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .authority a:hover {
    color: var(--color-ink);
    border-color: var(--color-orange);
  }
  .whispers-lead {
    color: var(--color-muted);
    margin-top: var(--space-2);
  }

  .complementary-label {
    margin: var(--space-6) 0 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .complementary-label a {
    color: var(--color-blue);
    font-weight: 600;
  }

  .client-marquee {
    margin-top: var(--space-8);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .client-marquee-track {
    display: flex;
    width: max-content;
    gap: var(--space-12);
    animation: marquee-scroll 28s linear infinite;
  }
  .client-marquee:hover .client-marquee-track {
    animation-play-state: paused;
  }
  .client-item {
    display: flex;
    align-items: center;
    height: 52px;
    flex-shrink: 0;
    background: var(--color-white);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
  }
  .client-item img {
    max-height: 100%;
    max-width: 130px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.6;
    transition: opacity var(--duration-standard) var(--ease-standard), filter var(--duration-standard) var(--ease-standard);
  }
  .client-marquee:hover .client-item img {
    filter: grayscale(0);
    opacity: 1;
  }
  .client-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-navy);
    opacity: 0.7;
    white-space: nowrap;
  }
</style>
