---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTABlock from '../components/CTABlock.astro';
import { withBase } from '../utils/url';

const verbatims = [
  { name: 'Julie', time: '09:14', color: '#5b8def', text: "Encore une transfo qui devient LA priorité n°1... comme les 3 précédentes 😅" },
  { name: 'Marc', time: '09:22', color: '#e3a651', text: "On a fait 3 ateliers. On sait ce qu'il faut faire. Il manque juste... quelqu'un qui décide ?" },
  { name: 'Sophie', time: '09:37', color: '#4fb0a5', text: 'On appelle ça "co-construction" mais les décisions sont déjà prises hein, on le sait tous' },
  { name: 'Karim', time: '10:02', color: '#e2727a', text: "Tout le monde dit oui en réunion. Après, dans les couloirs... plus personne n'y croit" },
  { name: 'Camille', time: '10:15', color: '#7d8fe3', text: 'On ressort avec 40 post-it. Lundi matin, on fait quoi concrètement ? 🤷' },
  { name: 'Thomas', time: '10:41', color: '#2d9d7a', text: 'On nous demande d\'"embarquer" les équipes mais le cap change toutes les 2 semaines' },
];

const offers = [
  {
    num: '01 · Décision',
    title: 'Décider ensemble',
    text: 'Pour sortir des discussions qui tournent en rond et transformer un sujet complexe en décision claire.',
    href: withBase('/offres/decider-ensemble/'),
    ribbon: false,
  },
  {
    num: "02 · Alignement",
    title: "Aligner l'équipe",
    text: 'Pour créer une direction commune, traiter les divergences et remettre le collectif en mouvement.',
    href: withBase('/offres/aligner-equipe/'),
    ribbon: true,
  },
  {
    num: '03 · Fonctionnement',
    title: 'Installer une dynamique durable',
    text: "Pour faire évoluer la prise de décision, les responsabilités, les rituels et l'autonomie dans le temps.",
    href: withBase('/offres/dynamique-durable/'),
    ribbon: false,
  },
];

const doChecks = [
  { i: '1', title: "Cadrer l'enjeu", text: 'Que faut-il comprendre, traiter ou décider ?' },
  { i: '2', title: 'Concevoir le processus', text: 'Qui contribue, à quel moment, avec quelles limites ?' },
  { i: '3', title: 'Faciliter et rendre visible', text: 'Faire émerger, structurer, arbitrer et garder une trace.' },
  { i: '4', title: 'Préparer la suite', text: 'Responsables, décisions, feuille de route et suivi.' },
];

const whoChecks = [
  { i: 'V', title: 'Une vision', text: 'Des organisations où les personnes savent ce qui compte et dans quel cadre agir.' },
  { i: 'M', title: 'Une mission', text: 'Concevoir de meilleures conversations pour produire de meilleures décisions.' },
  { i: 'A', title: 'Une approche', text: 'Partir du résultat attendu avant de choisir les méthodes et les outils.' },
];

const method = [
  { title: 'Donner à voir', text: 'Clarifier les enjeux et rendre visibles les idées, les défis et les opportunités.' },
  { title: 'Faire participer', text: "Faire émerger l'intelligence collective et créer les conditions de l'engagement." },
  { title: 'Décider', text: 'Transformer les échanges en choix concrets. Prioriser. Aligner les énergies.' },
  { title: 'Agir', text: 'Passer des intentions aux actions et construire un plan réaliste et mobilisateur.' },
  { title: 'Apprendre', text: 'Observer, ajuster et progresser ensemble.' },
];

const complementary = [
  { num: 'Visuel', title: 'Facilitation graphique', text: 'Donner à voir les idées, décisions et parcours d’un collectif.' },
  { num: 'Leadership', title: 'Diagnostic Leader Ancré', text: 'Prendre du recul, poser un cadre et ne plus tout porter seul.' },
  { num: 'Formation', title: 'Formation professionnelle', text: 'Transmettre les techniques de facilitation et de pensée visuelle.' },
];
const complementaryMore = ['Mentorat Leader', "Conception d'événements", 'Décoincés du Crayon'];

const clients = [
  { name: 'Air France KLM', logo: '/logos/air-france-klm.png' },
  { name: 'Louis Vuitton', logo: '/logos/louis-vuitton.svg' },
  { name: 'PwC', logo: '/logos/pwc.webp' },
  { name: 'MG2Mix', logo: '/logos/mg2mix.png' },
  { name: 'Ressource SI', logo: '/logos/ressources.png' },
  { name: 'Mairie de Valbonne' },
  { name: 'JCI Monaco', logo: '/logos/jci-monaco.png' },
  { name: 'URSSAF', logo: '/logos/urssaf.webp' },
  { name: "Commune d'Angers" },
  { name: 'CAF Rhône-Alpes' },
  { name: 'CEC', logo: '/logos/cec.png' },
  { name: 'Fibois Sud' },
  { name: 'Osan We', logo: '/logos/osanwe.png' },
  { name: 'IA2P' },
  { name: 'MediaSchool' },
];
---

<Layout
  title="by Nicolas Verdot — Du collectif qui discute au collectif qui agit vraiment"
  description="Facilitation, séminaires, facilitation graphique, coaching, IA et formations pour aider les collectifs à clarifier, décider et passer à l'action."
  path="/"
>
  <Hero />

  <section class="offers" id="accompagnements" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Trois portes d'entrée</p>
          <h2>Par quel sujet commencer ?</h2>
        </div>
        <p>Le site ne présente pas un catalogue de compétences. Il vous aide à reconnaître la situation que vous vivez, à vous situer grâce à un diagnostic et à comprendre ce que vous pouvez obtenir.</p>
      </div>
      <div class="cards">
        {offers.map((offer) => (
          <article class="card">
            {offer.ribbon && <div class="ribbon">CŒUR D'OFFRE</div>}
            <div class="num">{offer.num}</div>
            <h3>{offer.title}</h3>
            <p>{offer.text}</p>
            <a class="card-link" href={offer.href}>Explorer l'offre et faire le test</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="whispers" data-reveal>
    <div class="container">
      <p class="eyebrow">Ce que les équipes pensent tout bas</p>
      <h2 class="prose">Les phrases qu'on entend dans les couloirs, jamais en réunion.</h2>
      <div class="wa-grid">
        {verbatims.map((v) => (
          <div class="wa-row">
            <span class="wa-avatar" style={`background:${v.color}`}>{v.name.charAt(0)}</span>
            <div class="wa-bubble">
              <span class="wa-name" style={`color:${v.color}`}>{v.name}</span>
              <p class="wa-text">{v.text}</p>
              <span class="wa-time">{v.time}</span>
              <span class="wa-heart" aria-hidden="true">❤</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt" data-reveal>
    <div class="container split">
      <div>
        <p class="eyebrow">Ce que je fais réellement</p>
        <h2>Je ne viens pas seulement animer une salle.</h2>
        <p class="hero-copy">Le travail commence avant : clarifier l'intention, comprendre le système, identifier le niveau réel de participation et concevoir la conversation qui permettra d'obtenir un résultat exploitable.</p>
        <div class="checks">
          {doChecks.map((c) => (
            <div class="check"><i>{c.i}</i><div><strong>{c.title}</strong><br /><span class="muted">{c.text}</span></div></div>
          ))}
        </div>
      </div>
      <div class="quote">
        <blockquote>Un bon séminaire ne se mesure pas au nombre de post-it. Il se mesure à ce qui devient plus clair après.</blockquote>
        <cite>Nicolas Verdot — Facilitateur, coach et formateur</cite>
      </div>
    </div>
  </section>

  <section class="section alt" data-reveal>
    <div class="container split">
      <div>
        <p class="eyebrow">Qui suis-je ?</p>
        <h2>Un facilitateur qui relie structure, collectif et pensée visuelle.</h2>
        <p class="hero-copy">Ancien développeur, coach agile, facilitateur, formateur et moniteur de plongée, j'ai construit une approche qui combine clarté, responsabilité, participation utile et mise en action.</p>
        <div class="checks">
          {whoChecks.map((c) => (
            <div class="check"><i>{c.i}</i><div><strong>{c.title}</strong><br /><span class="muted">{c.text}</span></div></div>
          ))}
        </div>
        <div class="actions">
          <a class="btn" href={withBase('/a-propos/')}>Découvrir ma vision et mon approche</a>
        </div>
      </div>
      <div class="quote">
        <blockquote>Je ne cherche pas à faire participer tout le monde à tout. Je cherche à donner à chacun une place utile dans un processus clair.</blockquote>
        <cite>Nicolas Verdot</cite>
      </div>
    </div>
  </section>

  <section class="section dark" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">La méthode</p>
          <h2>Un processus simple, jamais simpliste.</h2>
        </div>
        <p>Les méthodes changent selon le contexte. Les étapes, elles, restent lisibles.</p>
      </div>
      <div class="method">
        {method.map((m, i) => (
          <div class="step"><b>{String(i + 1).padStart(2, '0')}</b>{m.title} — {m.text}</div>
        ))}
      </div>
    </div>
  </section>

  <section data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Autres façons de travailler ensemble</p>
          <h2>Autour du cœur de métier</h2>
        </div>
        <p>Des offres complémentaires sans brouiller le positionnement principal.</p>
      </div>
      <div class="cards">
        {complementary.map((c) => (
          <article class="card">
            <div class="num">{c.num}</div>
            <h3>{c.title}</h3>
            <p>{c.text}</p>
            <a class="card-link" href={withBase('/contact/')}>Découvrir</a>
          </article>
        ))}
      </div>
      <p class="complementary-label">Et aussi : {complementaryMore.join(' · ')}.</p>
    </div>
  </section>

  <section class="trust" data-reveal>
    <div class="container">
      <p class="eyebrow center">Ils m'ont déjà fait confiance</p>
      <h2 class="prose center">Des contextes différents, un même enjeu : faire avancer le collectif.</h2>
    </div>
    <div class="client-marquee">
      <div class="client-marquee-track">
        {[...clients, ...clients].map((c, i) => (
          <span class="client-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
            {c.logo ? <img src={withBase(c.logo)} alt={c.name} loading="lazy" /> : <span class="client-text">{c.name}</span>}
          </span>
        ))}
      </div>
    </div>
  </section>

  <CTABlock
    eyebrow="Un sujet à débloquer ?"
    title="Commençons par la situation réelle."
    subtitle="Un premier échange permet de comprendre l'enjeu, le niveau de décision et de vérifier si mon intervention est pertinente."
  />
</Layout>

<style>
  .eyebrow.center {
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }
  .prose.center {
    max-width: var(--prose-max);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .whispers {
    position: relative;
    background-color: var(--color-cream);
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='160'%20height='160'%3E%3Cg%20fill='none'%20stroke='%23122033'%20stroke-width='1.6'%20stroke-linecap='round'%20stroke-linejoin='round'%20opacity='0.09'%3E%3Cpath%20d='M14%2018%20h26%20a4%204%200%200%201%204%204%20v14%20a4%204%200%200%201%20-4%204%20h-16%20l-6%206%20v-6%20h-4%20a4%204%200%200%201%20-4%20-4%20v-14%20a4%204%200%200%201%204%20-4%20z'/%3E%3Ccircle%20cx='120'%20cy='30'%20r='11'/%3E%3Cpath%20d='M115%2030%20l4%204%20l8%20-9'/%3E%3Cpath%20d='M40%2090%20v14%20M33%2097%20h14%20M45.5%2091.5%20l-11%2011%20M45.5%20102.5%20l-11%20-11'/%3E%3Cpath%20d='M120%20100%20v12%20M114%20106%20h12'/%3E%3Ccircle%20cx='90'%20cy='140'%20r='6'/%3E%3Ccircle%20cx='20'%20cy='130'%20r='2'/%3E%3Ccircle%20cx='28'%20cy='134'%20r='2'/%3E%3Ccircle%20cx='24'%20cy='142'%20r='2'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 160px 160px;
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .whispers {
      background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='160'%20height='160'%3E%3Cg%20fill='none'%20stroke='%23ffffff'%20stroke-width='1.6'%20stroke-linecap='round'%20stroke-linejoin='round'%20opacity='0.07'%3E%3Cpath%20d='M14%2018%20h26%20a4%204%200%200%201%204%204%20v14%20a4%204%200%200%201%20-4%204%20h-16%20l-6%206%20v-6%20h-4%20a4%204%200%200%201%20-4%20-4%20v-14%20a4%204%200%200%201%204%20-4%20z'/%3E%3Ccircle%20cx='120'%20cy='30'%20r='11'/%3E%3Cpath%20d='M115%2030%20l4%204%20l8%20-9'/%3E%3Cpath%20d='M40%2090%20v14%20M33%2097%20h14%20M45.5%2091.5%20l-11%2011%20M45.5%20102.5%20l-11%20-11'/%3E%3Cpath%20d='M120%20100%20v12%20M114%20106%20h12'/%3E%3Ccircle%20cx='90'%20cy='140'%20r='6'/%3E%3Ccircle%20cx='20'%20cy='130'%20r='2'/%3E%3Ccircle%20cx='28'%20cy='134'%20r='2'/%3E%3Ccircle%20cx='24'%20cy='142'%20r='2'/%3E%3C/g%3E%3C/svg%3E");
    }
  }
  :root[data-theme='dark'] .whispers {
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='160'%20height='160'%3E%3Cg%20fill='none'%20stroke='%23ffffff'%20stroke-width='1.6'%20stroke-linecap='round'%20stroke-linejoin='round'%20opacity='0.07'%3E%3Cpath%20d='M14%2018%20h26%20a4%204%200%200%201%204%204%20v14%20a4%204%200%200%201%20-4%204%20h-16%20l-6%206%20v-6%20h-4%20a4%204%200%200%201%20-4%20-4%20v-14%20a4%204%200%200%201%204%20-4%20z'/%3E%3Ccircle%20cx='120'%20cy='30'%20r='11'/%3E%3Cpath%20d='M115%2030%20l4%204%20l8%20-9'/%3E%3Cpath%20d='M40%2090%20v14%20M33%2097%20h14%20M45.5%2091.5%20l-11%2011%20M45.5%20102.5%20l-11%20-11'/%3E%3Cpath%20d='M120%20100%20v12%20M114%20106%20h12'/%3E%3Ccircle%20cx='90'%20cy='140'%20r='6'/%3E%3Ccircle%20cx='20'%20cy='130'%20r='2'/%3E%3Ccircle%20cx='28'%20cy='134'%20r='2'/%3E%3Ccircle%20cx='24'%20cy='142'%20r='2'/%3E%3C/g%3E%3C/svg%3E");
  }

  .wa-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6) var(--space-4);
    margin-top: var(--space-8);
  }
  .wa-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
  }
  .wa-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    margin-top: var(--space-1);
  }
  .wa-bubble {
    position: relative;
    background: var(--color-surface);
    border-radius: 4px var(--radius-sm) var(--radius-sm) var(--radius-sm);
    padding: var(--space-3) var(--space-4) var(--space-6);
    box-shadow: var(--shadow-sm);
    flex: 1;
  }
  .wa-name {
    display: block;
    font-weight: 700;
    font-size: 0.88rem;
    margin-bottom: 0.2em;
  }
  .wa-text {
    margin: 0;
    color: var(--color-ink);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .wa-time {
    position: absolute;
    right: var(--space-3);
    bottom: var(--space-2);
    font-size: 0.7rem;
    color: var(--color-faint);
  }
  .wa-heart {
    position: absolute;
    left: -8px;
    bottom: -8px;
    width: 22px;
    height: 22px;
    display: grid;
    place-items: center;
    background: var(--color-surface);
    border-radius: 50%;
    box-shadow: var(--shadow-sm);
    font-size: 0.7rem;
    color: var(--color-red-bright);
  }

  .complementary-label {
    margin: var(--space-6) 0 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .client-marquee {
    margin-top: var(--space-8);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .client-marquee-track {
    display: flex;
    width: max-content;
    gap: var(--space-12);
    animation: marquee-scroll 28s linear infinite;
  }
  .client-marquee:hover .client-marquee-track {
    animation-play-state: paused;
  }
  .client-item {
    display: flex;
    align-items: center;
    height: 52px;
    flex-shrink: 0;
    background: var(--color-white);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
  }
  .client-item img {
    max-height: 100%;
    max-width: 130px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.6;
    transition: opacity var(--duration-standard) var(--ease-standard), filter var(--duration-standard) var(--ease-standard);
  }
  .client-marquee:hover .client-item img {
    filter: grayscale(0);
    opacity: 1;
  }
  .client-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-navy);
    opacity: 0.7;
    white-space: nowrap;
  }
</style>
