---
import Layout from '../../layouts/Layout.astro';
import CTABlock from '../../components/CTABlock.astro';
import { withBase } from '../../utils/url';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content } = await article.render();
const dateFormatter = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

// Maillage interne automatique : 3 articles du même pilier, les plus récents.
const siblings = (await getCollection('articles', ({ data, slug }) => !data.draft))
  .filter((a) => a.slug !== article.slug && a.data.pillar === article.data.pillar)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.publishDate.toISOString().split('T')[0],
  inLanguage: 'fr-FR',
  author: {
    '@type': 'Person',
    name: 'Nicolas Verdot',
    jobTitle: 'Facilitateur, coach professionnel et formateur',
    url: new URL(withBase('/a-propos/'), Astro.site).toString(),
  },
  publisher: {
    '@type': 'Person',
    name: 'Nicolas Verdot',
  },
  mainEntityOfPage: new URL(withBase(`/blog/${article.slug}/`), Astro.site).toString(),
};
---

<Layout
  title={`${article.data.title} — by Nicolas Verdot`}
  description={article.data.description}
  path={`/blog/${article.slug}/`}
>
  <article class="post">
    <div class="container prose">
      <a href={withBase('/blog/')} class="back-link">← Tous les articles</a>
      <p class="eyebrow">{article.data.pillar}</p>
      <h1>{article.data.title}</h1>
      <p class="post-meta">Publié le {dateFormatter.format(article.data.publishDate)} — Nicolas Verdot</p>
      <div class="post-content">
        <Content />
      </div>

      {siblings.length > 0 && (
        <aside class="related" aria-label="Articles sur le même thème">
          <h2>Sur le même thème</h2>
          <ul>
            {siblings.map((s) => (
              <li><a href={withBase(`/blog/${s.slug}/`)}>{s.data.title}</a></li>
            ))}
          </ul>
        </aside>
      )}
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <CTABlock
    title="Un sujet précis à traiter avec votre équipe ?"
    subtitle="Parlons de votre situation pour voir quel format serait le plus utile."
  />
</Layout>

<style>
  .post {
    padding-top: var(--space-8);
  }
  .back-link {
    display: inline-block;
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-navy);
    text-decoration: none;
  }
  .post-meta {
    color: var(--color-faint);
    font-size: var(--text-sm);
  }
  .post-content {
    margin-top: var(--space-8);
    line-height: 1.75;
  }
  .post-content :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-8);
  }
  .post-content :global(ul) {
    padding-left: var(--space-6);
  }
  .post-content :global(li) {
    margin-bottom: var(--space-2);
  }
  .post-content :global(a) {
    color: var(--color-navy);
    font-weight: 600;
  }
  .related {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .related h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }
  .related ul {
    margin: 0;
    padding-left: var(--space-6);
  }
  .related li {
    margin-bottom: var(--space-2);
  }
  .related a {
    color: var(--color-navy);
    font-weight: 600;
  }
  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }
</style>
