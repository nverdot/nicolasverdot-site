---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import CTABlock from '../../components/CTABlock.astro';
import { withBase } from '../../utils/url';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const dateFormatter = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

// Une couleur de vignette fixe par pilier : la thématique se repère d'un
// coup d'œil dans la grille, avant même de lire l'étiquette.
const pillarVisuals: Record<string, string> = {
  'Décision et priorisation': '',
  'Réunions et séminaires': 'orange',
  'Intelligence collective concrète': 'teal',
  'Pensée visuelle': 'green',
  'Leadership et autonomie': 'deep',
  'Parcours personnel': 'navy',
};

// Seuls les piliers réellement publiés apparaissent en filtre, avec leur compte.
const pillars = [...new Set(articles.map((a) => a.data.pillar))].map((p) => ({
  name: p,
  count: articles.filter((a) => a.data.pillar === p).length,
}));
---

<Layout
  title="Blog — by Nicolas Verdot"
  description="Décision, priorisation, leadership, réunions, intelligence collective et pensée visuelle : des articles concrets pour faire avancer votre collectif."
  path="/blog/"
>
  <PageHero
    eyebrow="Blog & ressources"
    title="Des situations concrètes, pas des recettes toutes faites."
    summary="Décision, priorisation, leadership, réunions, intelligence collective, pensée visuelle : des articles pour reconnaître ce qui bloque votre collectif et voir comment y remédier."
  />

  <section class="section" data-reveal>
    <div class="container">
      <div class="blog-tools">
        <div class="blog-search">
          <input data-blog-search type="search" placeholder="Rechercher un article…" aria-label="Rechercher un article" />
        </div>
        <div class="filter-row" data-pillar-filters role="group" aria-label="Filtrer par thématique">
          <button type="button" class="filter-btn active" data-pillar-filter="">Tous <span class="filter-count">{articles.length}</span></button>
          {pillars.map((p) => (
            <button type="button" class="filter-btn" data-pillar-filter={p.name}>{p.name} <span class="filter-count">{p.count}</span></button>
          ))}
        </div>
      </div>

      {articles.length === 0 && <p class="prose">Les premiers articles arrivent bientôt.</p>}
      <div class="article-grid">
        {articles.map((article) => (
          <article class="article-card" data-article-card data-pillar={article.data.pillar}>
            <div class={`article-visual ${pillarVisuals[article.data.pillar] ?? ''}`}></div>
            <div class="article-body">
              <div class="num">{article.data.pillar}</div>
              <h3><a href={withBase(`/blog/${article.slug}/`)}>{article.data.title}</a></h3>
              <div class="article-meta"><span>{dateFormatter.format(article.data.publishDate)}</span></div>
              <p>{article.data.description}</p>
              <a class="card-link" href={withBase(`/blog/${article.slug}/`)}>Lire l'article</a>
            </div>
          </article>
        ))}
      </div>
      <p class="blog-empty" data-blog-empty hidden>Aucun article ne correspond à cette recherche. Essayez un autre mot-clé ou une autre thématique.</p>
    </div>
  </section>

  <CTABlock
    title="Un sujet précis à traiter avec votre équipe ?"
    subtitle="Parlons de votre situation pour voir quel format serait le plus utile."
  />
</Layout>

<style>
  .blog-tools {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }
  .filter-count {
    font-weight: 400;
    opacity: 0.65;
    font-size: 0.85em;
    margin-left: 0.25em;
  }
  .blog-empty {
    margin-top: var(--space-8);
    color: var(--color-muted);
  }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .article-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .article-card[hidden] {
    display: none;
  }
  .article-body {
    padding: var(--space-6);
  }
  .article-body h3 {
    font-size: var(--text-xl);
    margin: var(--space-2) 0;
  }
  .article-body h3 a {
    text-decoration: none;
    color: var(--color-navy);
  }
  .article-body p {
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 980px) {
    .article-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 680px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const searchInput = document.querySelector<HTMLInputElement>('[data-blog-search]');
  const filterButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-pillar-filter]'));
  const cards = document.querySelectorAll<HTMLElement>('[data-article-card]');
  const emptyMessage = document.querySelector<HTMLElement>('[data-blog-empty]');
  let activePillar = '';

  function applyFilters() {
    const term = (searchInput?.value || '').trim().toLowerCase();
    let visible = 0;
    cards.forEach((card) => {
      const matchesPillar = !activePillar || card.dataset.pillar === activePillar;
      const matchesTerm = !term || (card.textContent || '').toLowerCase().includes(term);
      card.hidden = !(matchesPillar && matchesTerm);
      if (!card.hidden) visible++;
    });
    if (emptyMessage) emptyMessage.hidden = visible > 0;
  }

  searchInput?.addEventListener('input', applyFilters);
  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activePillar = btn.dataset.pillarFilter || '';
      filterButtons.forEach((b) => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });
</script>
