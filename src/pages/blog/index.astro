---
import Layout from '../../layouts/Layout.astro';
import CTABlock from '../../components/CTABlock.astro';
import { withBase } from '../../utils/url';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const dateFormatter = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout
  title="Blog — by Nicolas Verdot"
  description="Décision, priorisation, leadership, réunions, intelligence collective et pensée visuelle : des articles concrets pour faire avancer votre collectif."
  path="/blog/"
>
  <section class="blog-hero" data-reveal>
    <div class="container prose">
      <p class="eyebrow">Blog</p>
      <h1>Des situations concrètes, pas des recettes toutes faites.</h1>
      <p class="lead">Décision, priorisation, leadership, réunions, intelligence collective, pensée visuelle : des articles pour reconnaître ce qui bloque votre collectif et voir comment y remédier.</p>
    </div>
  </section>

  <section class="blog-list" data-reveal>
    <div class="container">
      {articles.length === 0 && <p class="prose">Les premiers articles arrivent bientôt.</p>}
      <div class="article-grid">
        {articles.map((article) => (
          <a href={withBase(`/blog/${article.slug}/`)} class="article-card card-brut">
            <span class="article-pillar">{article.data.pillar}</span>
            <h2>{article.data.title}</h2>
            <p>{article.data.description}</p>
            <span class="article-date">{dateFormatter.format(article.data.publishDate)}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABlock
    title="Un sujet précis à traiter avec votre équipe ?"
    subtitle="Parlons de votre situation pour voir quel format serait le plus utile."
  />
</Layout>

<style>
  .blog-hero {
    padding-bottom: 0;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: var(--space-2);
  }
  .lead {
    color: var(--color-muted);
    font-size: var(--text-lg);
  }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }
  .article-card {
    display: block;
    background: var(--color-surface);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
  }
  .article-pillar {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-navy);
    margin-bottom: var(--space-3);
  }
  .article-card h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }
  .article-card p {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-3);
  }
  .article-date {
    font-size: var(--text-xs);
    color: var(--color-faint);
  }
</style>
