---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTABlock from '../components/CTABlock.astro';
import { withBase } from '../utils/url';
import { kits, bikabloKit } from '../data/materiel';

const whyChecks = [
  { i: '1', title: 'Se décharger mentalement', text: "Tout est là, à sa place, prêt à être utilisé. Je n'ai pas à y penser — je reste pleinement présent à l'humain et à la dynamique du collectif." },
  { i: '2', title: 'Une posture qui se voit', text: 'Arriver avec une valise de feutres bien rangée, cohérente et pensée pour l\'usage crée immédiatement un cadre professionnel et rassurant.' },
  { i: '3', title: 'Des outils alignés avec mes valeurs', text: 'Robustes, durables, rechargeables — conçus pour durer et être transmis, pas pour être jetés.' },
];
---

<Layout
  title="Guide du matériel facilitation graphique — by Nicolas Verdot"
  description="Le matériel Neuland que j'utilise et recommande, par usage : sketchnote, formation et atelier, capture graphique. Sélection d'ambassadeur, testée sur le terrain depuis 15 ans."
  path="/materiel/"
>
  <PageHero
    eyebrow="Matériel & recommandations"
    title="Le matériel que j'utilise (et pourquoi)"
    summary="Cela fait plus de 15 ans que je travaille avec du matériel Neuland. Voici ma sélection complète, testée sur le terrain, organisée par usage : sketchnote, formation & atelier, capture graphique."
    pills={['Ambassadeur Neuland', 'Démarche éco-responsable', 'Testé sur le terrain']}
  />

  <section class="section" data-reveal>
    <div class="container split">
      <div>
        <p class="eyebrow">Une relation de confiance construite dans la durée</p>
        <h2>Plus de 15 ans avec Neuland</h2>
        <p class="hero-copy">Ils m'accompagnent depuis mes débuts et ont évolué avec ma pratique, mes contextes d'intervention et mon exigence professionnelle. En <strong>2026</strong>, j'ai la chance de rejoindre les <strong>Ambassadeurs Neuland</strong>. C'est une fierté, mais surtout la reconnaissance d'une relation construite dans le temps, basée sur l'usage réel, le terrain et un alignement profond de valeurs.</p>
        <div class="checks">
          {whyChecks.map((c) => (
            <div class="check"><i>{c.i}</i><div><strong>{c.title}</strong><br /><span class="muted">{c.text}</span></div></div>
          ))}
        </div>
      </div>
      <div class="quote">
        <blockquote>J'ai encore, dans ma boîte à feutres, des marqueurs de plus de 10 ans. Et ils fonctionnent toujours.</blockquote>
        <cite>Nicolas Verdot — Ambassadeur Neuland</cite>
      </div>
    </div>
  </section>

  <section class="section alt" data-reveal>
    <div class="container prose">
      <p class="eyebrow">L'allié silencieux</p>
      <h2>Le matériel n'est jamais un détail</h2>
      <p>Avoir le bon matériel, bien pensé et bien organisé, me permet de me décharger mentalement de tout ce qui est technique et logistique. Cette sécurité me permet de rester pleinement présent à l'humain, à la dynamique du collectif et à ce qui se joue dans l'instant. Moins d'énergie dépensée sur la logistique, plus d'attention disponible pour l'écoute, l'observation et l'action.</p>
      <p>Quand le matériel est bien conçu, il devient un <strong>allié silencieux</strong> : il sécurise le cadre, réduit la charge mentale et permet de se concentrer sur l'essentiel — l'humain, la relation et l'action collective. Promouvoir des produits éco-responsables fait pleinement sens pour moi : c'est cohérent avec la manière dont j'accompagne les leaders et les équipes — dans la durée, avec attention, responsabilité et impact.</p>
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Trois boîtes à outils</p>
          <h2>Ma sélection, par usage</h2>
        </div>
        <p>Chaque kit correspond à un contexte réel d'intervention. Les liens renvoient directement vers la boutique Neuland.</p>
      </div>
      <nav class="kit-nav" aria-label="Aller à une boîte à outils">
        {kits.map((k) => (
          <a class="filter-btn" href={`#${k.id}`}>{k.label}</a>
        ))}
      </nav>
    </div>
  </section>

  {kits.map((kit, ki) => (
    <section class={`section${ki % 2 === 0 ? ' alt' : ''}`} id={kit.id} data-reveal>
      <div class="container">
        <div class="section-head">
          <div>
            <p class="eyebrow">Boîte à outils</p>
            <h2>{kit.title.replace('Boîte à outils — ', '')}</h2>
          </div>
          <p>{kit.intro}</p>
        </div>
        <div class="product-grid">
          {kit.products.map((product) => (
            <article class="product-card">
              <h3>{product.name}</h3>
              <p>{product.desc}</p>
              <a class="card-link" href={product.url} target="_blank" rel="sponsored noopener">Voir le produit</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section" data-reveal>
    <div class="container">
      <div class="panel">
        <p class="eyebrow">Bibliothèque d'icônes</p>
        <h2>En manque d'inspiration ?</h2>
        <p class="muted">Pour enrichir votre vocabulaire visuel, je recommande principalement le <strong>{bikabloKit.name}</strong> : des centaines d'icônes prêtes à être reproduites, pensées pour la facilitation graphique.</p>
        <a class="btn" href={bikabloKit.url} target="_blank" rel="sponsored noopener">Découvrir le kit Bikablo</a>
      </div>
    </div>
  </section>

  <section class="section alt" data-reveal>
    <div class="container prose">
      <p class="eyebrow">À noter</p>
      <h2>Transparence</h2>
      <p>En tant qu'ambassadeur Neuland, j'utilise ces outils professionnels dans mes formations en ligne, mes ateliers en présentiel et dans mon travail au quotidien. Les liens de cette page redirigent directement vers la boutique Neuland.com.</p>
      <p class="fine"><em>Les liens présents sur cette page sont des liens affiliés, sans coût supplémentaire pour vous. Je perçois une petite commission sur les achats effectués via ces liens. Cela ne change en rien mon intérêt personnel pour cette marque, que j'utilise depuis des années.</em></p>
    </div>
  </section>

  <CTABlock
    title="Envie d'échanger sur votre prochain événement ?"
    subtitle="Facilitation graphique, capture graphique, ou les deux — parlons de votre besoin."
  />
</Layout>

<style>
  .muted {
    color: var(--color-muted);
  }
  .panel .btn {
    margin-top: var(--space-4);
  }
  .kit-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }
  .product-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }
  .product-card h3 {
    font-size: var(--text-base);
    margin: 0;
  }
  .product-card p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-muted);
    flex-grow: 1;
  }
  .product-card .card-link {
    margin-top: var(--space-2);
  }
  @media (max-width: 900px) {
    .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 560px) {
    .product-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
