---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ApproachTimeline from '../components/ApproachTimeline.astro';
import CTABlock from '../components/CTABlock.astro';

const values = [
  { title: 'Clarté', text: "Nommer l'intention, les contraintes, la décision attendue et la place réelle de chacun." },
  { title: 'Responsabilité', text: 'Le collectif enrichit la décision, mais il ne doit pas permettre au décideur d\'éviter son rôle.' },
  { title: 'Participation utile', text: 'Faire contribuer les personnes là où leur expérience et leur regard apportent réellement de la valeur.' },
  { title: 'Simplicité', text: 'Utiliser des méthodes suffisamment structurées pour être solides, sans rendre le dispositif inutilement compliqué.' },
  { title: 'Autonomie', text: 'Construire des cadres qui permettent aux équipes d\'agir sans dépendre constamment du manager ou du consultant.' },
];

const approachSteps = [
  {
    title: 'Comprendre le système',
    text: 'Identifier les enjeux, les tensions, les parties prenantes, les contraintes et ce qui a déjà été essayé.',
    bullets: ['Écouter les acteurs clés', 'Repérer les tensions sous-jacentes', 'Voir ce qui a déjà été tenté'],
  },
  {
    title: "Clarifier l'intention",
    text: 'Définir ce que les participants doivent comprendre, produire, prioriser ou décider.',
    bullets: ['Nommer le résultat attendu', 'Aligner les parties prenantes', 'Prioriser ce qui compte'],
  },
  {
    title: 'Concevoir le processus',
    text: 'Choisir le niveau de participation, le rythme, les séquences, les supports et la manière de restituer.',
    bullets: ['Choisir le bon format', 'Séquencer les temps forts', 'Prévoir la restitution'],
  },
  {
    title: 'Créer les conditions du dialogue',
    text: "Poser un cadre suffisamment sécurisant pour permettre l'expression, le désaccord et l'arbitrage.",
    bullets: ['Poser un cadre clair', 'Autoriser le désaccord', "Préparer l'arbitrage"],
  },
  {
    title: 'Rendre visible',
    text: 'Matérialiser les idées, les liens, les choix et les engagements grâce à la facilitation graphique.',
    bullets: ['Capturer en direct', 'Relier les idées entre elles', 'Garder une trace partagée'],
  },
  {
    title: 'Préparer la suite',
    text: 'Transformer la production collective en responsabilités, décisions, échéances et mécanismes de suivi.',
    bullets: ['Attribuer les responsabilités', 'Fixer les échéances', 'Installer un suivi'],
  },
];

const toolGroups = [
  { title: 'Conversations et décisions', tags: ['ORID', 'Consensus Workshop', 'Cadres de décision', 'Priorisation'] },
  { title: 'Intelligence collective et grands groupes', tags: ['Technology of Participation', 'World Café', 'Open Space', "Ateliers de vision"] },
  { title: 'Organisation et travail des équipes', tags: ['Coaching', 'Rétrospectives', "Théorie polyvagale"] },
  { title: 'Pensée visuelle et apprentissage', tags: ['Facilitation graphique', 'Sketchnoting', 'Management visuel', 'Design pédagogique'] },
];

const shifts = [
  "de réunions longues à des conversations utiles",
  "de décisions floues à des choix partagés",
  "de participants passifs à des personnes engagées",
  "d'idées dispersées à une vision commune",
  "d'un plan théorique à une dynamique d'action",
  "d'une transformation subie à une transformation construite",
];
---

<Layout
  title="Mon approche de la facilitation — by Nicolas Verdot"
  description="Découvrez l'approche de Nicolas Verdot : donner à voir, faire participer, décider, agir et apprendre pour permettre aux collectifs de donner le meilleur d'eux-mêmes."
  path="/approche/"
>
  <PageHero
    eyebrow="Approche"
    title="Je pars du résultat attendu, pas de ma boîte à outils."
    summary="Les réponses sont souvent déjà présentes dans le collectif. Mon rôle consiste à concevoir le cadre qui permet aux idées de circuler, aux points de vue de se rencontrer, aux décisions d'émerger et à l'action de devenir possible."
  />

  <section class="not-thinking" data-reveal>
    <div class="container prose">
      <h2>Je ne suis pas là pour penser à la place du groupe.</h2>
      <p>Vous êtes les experts de votre métier. Vous connaissez votre contexte, vos contraintes, vos clients, vos bénéficiaires, vos usagers et vos équipes.</p>
      <p>Je n'interviens pas pour imposer une réponse toute faite. J'interviens comme architecte du cadre : je conçois la manière dont le collectif va se parler, réfléchir, décider et avancer.</p>
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Valeurs</p>
          <h2>Les principes qui ne sont pas négociables</h2>
        </div>
        <p>Ces valeurs ne sont pas des mots affichés sur un mur. Elles influencent concrètement la manière dont je cadre, conçois et anime une intervention.</p>
      </div>
      <div class="values-grid">
        {values.map((v, i) => (
          <article class="value-card">
            <div class="value-number">{i + 1}</div>
            <h3>{v.title}</h3>
            <p>{v.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="process" data-reveal>
    <div class="container">
      <h2 class="prose">Une approche en cinq leviers</h2>
      <ProcessSteps />
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">La méthode, en détail</p>
          <h2>Un déroulé pensé, jamais imposé.</h2>
        </div>
        <p>Les méthodes sont choisies après avoir compris le contexte. Un World Café, un ORID ou un Open Space ne sont jamais une réponse en eux-mêmes.</p>
      </div>
      <ApproachTimeline steps={approachSteps} />
    </div>
  </section>

  <section class="section alt" data-reveal>
    <div class="container tools-layout">
      <div>
        <p class="eyebrow">Approche et outils</p>
        <h2>Une boîte à outils large, utilisée avec discernement.</h2>
        <p class="hero-copy">Selon votre besoin, je mobilise plusieurs registres : conversation et décision, intelligence collective, organisation d'équipe et pensée visuelle.</p>
        <div class="article-callout">
          <h3>Le principe</h3>
          <p>Je ne choisis pas une méthode parce qu'elle est à la mode ou agréable à animer. Je la choisis parce qu'elle aide le groupe à produire le résultat attendu dans le temps disponible.</p>
        </div>
      </div>

      <div class="tool-groups">
        {toolGroups.map((group) => (
          <section class="tool-group">
            <h3>{group.title}</h3>
            <div class="tool-tags">
              {group.tags.map((tag) => <span class="tool-tag">{tag}</span>)}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <section class="shifts" data-reveal>
    <div class="container prose">
      <h2>Ce que cette approche change</h2>
      <p>Elle permet de passer :</p>
      <ul class="shift-list">
        {shifts.map((shift) => <li>{shift}</li>)}
      </ul>
    </div>
  </section>

  <section class="context" data-reveal>
    <div class="container prose">
      <h2>Une approche adaptée à votre contexte</h2>
      <p>Chaque collectif est différent. Une équipe de direction ne fonctionne pas comme une association de terrain. Une mairie ne fonctionne pas comme une startup.</p>
      <p>C'est pourquoi je ne propose pas de déroulé standard. Je conçois chaque intervention à partir de votre contexte, de vos enjeux, des personnes présentes, du temps disponible, des résultats attendus et de l'énergie réelle du groupe.</p>
    </div>
  </section>

  <CTABlock
    title="Et si le collectif portait déjà une partie de la réponse ?"
    subtitle="Parlons de votre contexte et des conditions à créer pour faire émerger le meilleur de votre collectif."
  />
</Layout>

<style>
  .not-thinking {
    background: var(--color-surface);
  }
  .shift-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .shift-list li {
    padding-left: var(--space-6);
    position: relative;
  }
  .shift-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-orange);
    font-weight: 700;
  }
</style>
