---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ApproachTimeline from '../components/ApproachTimeline.astro';
import CTABlock from '../components/CTABlock.astro';
import { SITE } from '../data/site';
import { withBase } from '../utils/url';

const shifts = [
  'de réunions qui tournent en rond à des conversations qui débouchent sur une décision',
  "de décisions qui reviennent sur la table chaque mois à des choix qui tiennent",
  "de participants qui hochent la tête à des équipes qui s'engagent vraiment",
  "d'une stratégie que trois personnes comprennent à une direction que tout le monde partage",
  "d'une énergie dispersée sur dix sujets à un plan d'action que le collectif porte",
];

const diffs = [
  {
    title: 'Vous gardez la main',
    text: "Le collectif enrichit la décision, il ne la prend pas à votre place. Vous restez décideur — en sachant enfin sur quoi vous appuyer.",
  },
  {
    title: 'Ça se voit tout de suite',
    text: 'Chaque échange est capturé et rendu visible en direct, grâce à la facilitation graphique. Personne ne repart en se demandant ce qui a été dit.',
  },
  {
    title: 'Vos équipes continuent sans moi',
    text: "Mon objectif n'est pas de revenir animer votre prochaine réunion. C'est que vous n'en ayez plus besoin.",
  },
];

const approachSteps = [
  {
    title: 'Comprendre le système',
    text: 'Avant toute proposition, je prends le temps de comprendre votre contexte réel : qui porte quoi, ce qui a déjà été essayé, ce qui bloque en silence.',
    bullets: ['Écouter les acteurs clés', 'Repérer les tensions sous-jacentes', 'Voir ce qui a déjà été tenté'],
  },
  {
    title: "Clarifier l'intention",
    text: "On ne conçoit rien tant que le résultat attendu n'est pas nommé noir sur blanc — et partagé par ceux qui doivent trancher.",
    bullets: ['Nommer le résultat attendu', 'Aligner les parties prenantes', 'Prioriser ce qui compte'],
  },
  {
    title: 'Concevoir le dispositif',
    text: "Le format se choisit après le diagnostic, jamais avant. Un séminaire de direction ne se prépare pas comme un atelier d'équipe.",
    bullets: ['Choisir le bon format', 'Séquencer les temps forts', 'Prévoir la restitution'],
  },
  {
    title: 'Créer les conditions du dialogue',
    text: 'Un cadre suffisamment sécurisant pour que les désaccords sortent — et se traitent — plutôt que de couver après la réunion.',
    bullets: ['Poser un cadre clair', 'Autoriser le désaccord', "Préparer l'arbitrage"],
  },
  {
    title: 'Rendre visible',
    text: "Les idées, les liens et les choix se matérialisent en direct grâce à la facilitation graphique — la mémoire du collectif ne dépend plus d'un compte rendu.",
    bullets: ['Capturer en direct', 'Relier les idées entre elles', 'Garder une trace partagée'],
  },
  {
    title: 'Ancrer la suite',
    text: "Une intervention réussie se juge à ce qui se passe après. Responsables, échéances, rituels de suivi : rien ne repart flou.",
    bullets: ['Attribuer les responsabilités', 'Fixer les échéances', 'Installer un suivi'],
  },
];
---

<Layout
  title="Mon approche de la facilitation — by Nicolas Verdot"
  description="Vous n'avez pas besoin d'une méthode de plus, vous avez besoin que ça avance. Voici comment je conçois chaque intervention pour transformer vos discussions en décisions et vos décisions en actions."
  path="/approche/"
>
  <PageHero
    eyebrow="Comment ça se passe"
    title="Vous n'avez pas besoin d'une méthode de plus. Vous avez besoin que ça avance."
    summary="Vous avez déjà les bonnes personnes autour de la table, les bonnes idées, la bonne énergie. Ce qui manque souvent, c'est le cadre qui transforme tout ça en décisions claires et en actions qui tiennent. C'est exactement ce que je conçois avec vous — jamais standardisé, toujours à partir de votre contexte réel."
    pills={['Décider plus vite', "Aligner l'équipe", 'Passer à l\'action']}
  />

  <div class="container hero-cta-row" data-reveal>
    <a href={SITE.bookingUrl} class="btn" target="_blank" rel="noopener">Réserver un appel découverte</a>
    <a href={withBase('/contact/')} class="btn-outline">J'ai un projet à lancer</a>
  </div>

  <section class="section" data-reveal>
    <div class="container prose">
      <h2>Le symptôme n'est presque jamais celui qu'on croit.</h2>
      <p>« On manque de temps », « l'équipe n'est pas assez engagée », « la com' est mauvaise » : ce sont rarement les vraies causes. Le plus souvent, c'est l'absence d'un cadre qui permette aux discussions de déboucher sur quelque chose. Voici ce que ça change, concrètement :</p>
      <ul class="shift-list">
        {shifts.map((shift) => <li>{shift}</li>)}
      </ul>
    </div>
  </section>

  <section class="section alt" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Pourquoi ça marche</p>
          <h2>Trois choses que je ne fais jamais à votre place</h2>
        </div>
      </div>
      <div class="diffs-grid">
        {diffs.map((d) => (
          <article class="value-card">
            <h3>{d.title}</h3>
            <p>{d.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Le déroulé</p>
          <h2>Six étapes, jamais un format imposé</h2>
        </div>
        <p>La méthode se choisit après avoir compris votre contexte — jamais avant. World Café, atelier de décision, séminaire de direction : le bon format dépend d'où vous en êtes, pas de mes préférences.</p>
      </div>
      <ApproachTimeline steps={approachSteps} />
    </div>
  </section>

  <section class="section alt dual-cta-section" data-reveal>
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Prochaine étape</p>
          <h2>Deux façons d'avancer</h2>
        </div>
      </div>
      <div class="dual-cta">
        <a href={SITE.bookingUrl} class="dual-cta-card" target="_blank" rel="noopener">
          <p class="eyebrow">Vous hésitez encore</p>
          <h3>Réservez un appel découverte</h3>
          <p>30 minutes pour poser votre contexte à plat et voir, ensemble, si je peux vous aider. Sans engagement.</p>
          <span class="dual-cta-link">Choisir un créneau →</span>
        </a>
        <a href={withBase('/contact/')} class="dual-cta-card">
          <p class="eyebrow">Vous savez déjà ce qu'il vous faut</p>
          <h3>Lancez votre projet ou votre séminaire</h3>
          <p>Décrivez votre contexte en quelques lignes, je reviens vers vous avec une proposition concrète.</p>
          <span class="dual-cta-link">Décrire mon projet →</span>
        </a>
      </div>
    </div>
  </section>

  <CTABlock
    title="Et si le collectif portait déjà une partie de la réponse ?"
    subtitle="Parlons de votre contexte et des conditions à créer pour faire émerger le meilleur de votre collectif."
  />
</Layout>

<style>
  .hero-cta-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }
  .shift-list {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .shift-list li {
    padding-left: var(--space-6);
    position: relative;
  }
  .shift-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-orange);
    font-weight: 700;
  }

  .diffs-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .dual-cta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }
  .dual-cta-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    text-decoration: none;
    color: inherit;
    transition: transform 200ms var(--ease-out), box-shadow 200ms var(--ease-out), border-color 200ms var(--ease-out);
  }
  .dual-cta-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-orange);
  }
  .dual-cta-card h3 {
    margin: var(--space-2) 0 var(--space-3);
    font-size: var(--text-xl);
  }
  .dual-cta-card p:not(.eyebrow) {
    color: var(--color-muted);
    margin: 0 0 var(--space-4);
  }
  .dual-cta-link {
    font-weight: 700;
    color: var(--color-orange-ink);
  }

  @media (max-width: 800px) {
    .diffs-grid {
      grid-template-columns: 1fr;
    }
    .dual-cta {
      grid-template-columns: 1fr;
    }
  }
</style>
